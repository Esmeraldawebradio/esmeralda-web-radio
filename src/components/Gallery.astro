---
interface GalleryItem {
  src: string;
  alt: string;
  caption?: string;
}

const PHOTOS: GalleryItem[] = [
  { src: "https://picsum.photos/seed/pindobacu1/400/300", alt: "Vista rural de Pindobaçu", caption: "Pindobaçu, BA" },
  { src: "https://picsum.photos/seed/caatinga/400/520", alt: "Caatinga baiana", caption: "Caatinga, Sertão da Bahia" },
  { src: "https://picsum.photos/seed/pindobacu2/400/280", alt: "Estrada de Pindobaçu", caption: "Estrada rural, Pindobaçu, BA" },
  { src: "https://picsum.photos/seed/sertaobahia/400/540", alt: "Sertão nordestino", caption: "Sertão Baiano" },
  { src: "https://picsum.photos/seed/pindobacu3/400/480", alt: "Paisagem de Pindobaçu", caption: "Interior de Pindobaçu, BA" },
  { src: "https://picsum.photos/seed/chapadabahia/400/320", alt: "Chapada Diamantina", caption: "Chapada Diamantina, BA" },
];
---

<section id="galeria" class="gallery-section" aria-labelledby="gallery-title">
  <div class="container">
    <header class="section-header">
      <h2 id="gallery-title" class="section-title">Galeria de Fotos</h2>
      <p class="section-subtitle">Belezas de Pindobaçu e da Bahia em cada clique</p>
    </header>

    <div class="gallery-grid">
      {PHOTOS.map((photo) => (
        <a
          href={photo.src.replace(/\/\d+(\/\d+)?$/, '/800')}
          class="gallery-item"
          target="_blank"
          rel="noopener"
          aria-label={photo.alt}
        >
          <img src={photo.src} alt={photo.alt} loading="lazy" />
          {photo.caption && (
            <div class="gallery-caption">
              <span>{photo.caption}</span>
            </div>
          )}
        </a>
      ))}
    </div>
  </div>
</section>

<script>
  (function() {
    const SEEDS = ['pindobacu', 'caatinga', 'sertaobahia', 'chapadabahia', 'nordeste', 'pindobacu'];
    let seedIndex = 0;

    function seedURL(w, h) {
      const s = SEEDS[seedIndex % SEEDS.length];
      seedIndex++;
      return 'https://picsum.photos/seed/' + s + seedIndex + '/' + w + '/' + h;
    }

    const grid = document.querySelector('.gallery-grid');
    if (!grid) return;
    const items = grid.querySelectorAll('.gallery-item');
    if (!items.length) return;

    function refresh() {
      seedIndex = 0;
      items.forEach(item => {
        const img = item.querySelector('img');
        if (!img) return;
        const w = img.naturalWidth || 400;
        const h = img.naturalHeight || 300;
        img.style.opacity = '0';
        const url = seedURL(w, h);
        const newImg = new Image();
        newImg.onload = function() {
          img.src = this.src;
          img.style.opacity = '1';
          item.href = url.replace(/\/\d+\/\d+$/, '/800/600');
        };
        newImg.src = url;
      });
    }

    setInterval(refresh, 600000);
  })();
</script>

<style is:global>
  .gallery-section {
    padding: var(--space-10) 0;
    background: var(--color-surface);
  }

  .gallery-grid {
    column-count: 3;
    column-gap: var(--space-2);
  }

  @media (max-width: 768px) {
    .gallery-grid { column-count: 2; }
  }

  @media (max-width: 480px) {
    .gallery-grid { column-count: 1; }
  }

  .gallery-item {
    position: relative;
    overflow: hidden;
    border-radius: var(--radius-md);
    display: block;
    margin-bottom: var(--space-2);
    break-inside: avoid;
    transition: all var(--duration-base) var(--ease-spring);
  }
  .gallery-item:hover {
    transform: scale(1.03) translateY(-2px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.15);
    text-decoration: none;
  }

  .gallery-item img {
    width: 100%;
    display: block;
    transition: transform var(--duration-slow) var(--ease-out-quart), opacity 0.4s ease;
  }
  .gallery-item:hover img {
    transform: scale(1.08);
  }

  .gallery-caption {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: var(--space-2) var(--space-3);
    background: linear-gradient(transparent, rgba(0,0,0,0.7));
    color: white;
    font-size: var(--text-xs);
    font-weight: var(--weight-medium);
    opacity: 0;
    transition: opacity var(--duration-base) var(--ease-out-quart);
  }
  .gallery-item:hover .gallery-caption {
    opacity: 1;
  }
</style>
