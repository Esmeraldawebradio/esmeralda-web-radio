---
interface GalleryItem {
  src: string;
  full: string;
  page: string;
  alt: string;
  caption?: string;
}

const PHOTOS: GalleryItem[] = [
  {
    src: "https://upload.wikimedia.org/wikipedia/commons/thumb/4/46/Chapada_norte_-_panoramio.jpg/640px-Chapada_norte_-_panoramio.jpg",
    full: "https://upload.wikimedia.org/wikipedia/commons/4/46/Chapada_norte_-_panoramio.jpg",
    page: "https://commons.wikimedia.org/wiki/File:Chapada_norte_-_panoramio.jpg",
    alt: "Chapada Norte em Pindobaçu",
    caption: "Chapada Norte, Pindobaçu, BA"
  },
  {
    src: "https://upload.wikimedia.org/wikipedia/commons/thumb/e/ea/Monte_santa_cruz_-_panoramio.jpg/640px-Monte_santa_cruz_-_panoramio.jpg",
    full: "https://upload.wikimedia.org/wikipedia/commons/e/ea/Monte_santa_cruz_-_panoramio.jpg",
    page: "https://commons.wikimedia.org/wiki/File:Monte_santa_cruz_-_panoramio.jpg",
    alt: "Monte Santa Cruz em Pindobaçu",
    caption: "Monte Santa Cruz, Pindobaçu, BA"
  },
  {
    src: "https://upload.wikimedia.org/wikipedia/commons/thumb/7/71/Monte_santa_Cruz%2C_cruzeiro_de_Pindoba%C3%A7u_-_panoramio.jpg/640px-Monte_santa_Cruz%2C_cruzeiro_de_Pindoba%C3%A7u_-_panoramio.jpg",
    full: "https://upload.wikimedia.org/wikipedia/commons/7/71/Monte_santa_Cruz%2C_cruzeiro_de_Pindoba%C3%A7u_-_panoramio.jpg",
    page: "https://commons.wikimedia.org/wiki/File:Monte_santa_Cruz,_cruzeiro_de_Pindoba%C3%A7u_-_panoramio.jpg",
    alt: "Cruzeiro no Monte Santa Cruz em Pindobaçu",
    caption: "Cruzeiro do Monte Santa Cruz, Pindobaçu, BA"
  },
  {
    src: "https://upload.wikimedia.org/wikipedia/commons/thumb/2/28/Ponte_sobre_rio_Capivari_-_panoramio.jpg/640px-Ponte_sobre_rio_Capivari_-_panoramio.jpg",
    full: "https://upload.wikimedia.org/wikipedia/commons/2/28/Ponte_sobre_rio_Capivari_-_panoramio.jpg",
    page: "https://commons.wikimedia.org/wiki/File:Ponte_sobre_rio_Capivari_-_panoramio.jpg",
    alt: "Ponte sobre o Rio Capivari em Pindobaçu",
    caption: "Ponte sobre o Rio Capivari, Pindobaçu, BA"
  },
  {
    src: "https://upload.wikimedia.org/wikipedia/commons/thumb/4/46/Chapada_norte_-_panoramio.jpg/480px-Chapada_norte_-_panoramio.jpg",
    full: "https://upload.wikimedia.org/wikipedia/commons/4/46/Chapada_norte_-_panoramio.jpg",
    page: "https://commons.wikimedia.org/wiki/File:Chapada_norte_-_panoramio.jpg",
    alt: "Vista da Chapada Norte em Pindobaçu",
    caption: "Serra da Carnaíba, Pindobaçu, BA"
  },
  {
    src: "https://upload.wikimedia.org/wikipedia/commons/thumb/2/28/Ponte_sobre_rio_Capivari_-_panoramio.jpg/480px-Ponte_sobre_rio_Capivari_-_panoramio.jpg",
    full: "https://upload.wikimedia.org/wikipedia/commons/2/28/Ponte_sobre_rio_Capivari_-_panoramio.jpg",
    page: "https://commons.wikimedia.org/wiki/File:Ponte_sobre_rio_Capivari_-_panoramio.jpg",
    alt: "Rio Capivari em Pindobaçu",
    caption: "Rio Capivari, Pindobaçu, BA"
  },
];
---

<section id="galeria" class="gallery-section" aria-labelledby="gallery-title">
  <div class="container">
    <header class="section-header">
      <h2 id="gallery-title" class="section-title">Galeria de Fotos</h2>
      <p class="section-subtitle">Belezas de Pindobaçu e da Bahia em cada clique</p>
    </header>

    <div class="gallery-grid">
      {PHOTOS.map((photo) => (
        <a
          href={photo.page}
          class="gallery-item"
          target="_blank"
          rel="noopener"
          aria-label={photo.alt}
        >
          <img src={photo.src} alt={photo.alt} loading="lazy" />
          {photo.caption && (
            <div class="gallery-caption">
              <span>{photo.caption}</span>
            </div>
          )}
        </a>
      ))}
    </div>

    <p class="gallery-credit">Fotos: Erick Perfil (CC BY-SA 3.0 via Wikimedia Commons)</p>
  </div>
</section>

<style is:global>
  .gallery-section {
    padding: var(--space-10) 0;
    background: var(--color-surface);
  }

  .gallery-grid {
    column-count: 3;
    column-gap: var(--space-2);
  }

  @media (max-width: 768px) {
    .gallery-grid { column-count: 2; }
  }

  @media (max-width: 480px) {
    .gallery-grid { column-count: 1; }
  }

  .gallery-item {
    position: relative;
    overflow: hidden;
    border-radius: var(--radius-md);
    display: block;
    margin-bottom: var(--space-2);
    break-inside: avoid;
    transition: all var(--duration-base) var(--ease-spring);
  }
  .gallery-item:hover {
    transform: scale(1.03) translateY(-2px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.15);
    text-decoration: none;
  }

  .gallery-item img {
    width: 100%;
    display: block;
    transition: transform var(--duration-slow) var(--ease-out-quart), opacity 0.4s ease;
  }
  .gallery-item:hover img {
    transform: scale(1.08);
  }

  .gallery-caption {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: var(--space-2) var(--space-3);
    background: linear-gradient(transparent, rgba(0,0,0,0.7));
    color: white;
    font-size: var(--text-xs);
    font-weight: var(--weight-medium);
    opacity: 0;
    transition: opacity var(--duration-base) var(--ease-out-quart);
  }
  .gallery-item:hover .gallery-caption {
    opacity: 1;
  }

  .gallery-credit {
    text-align: center;
    font-size: var(--text-xs);
    color: var(--color-ink-subtle);
    margin-top: var(--space-4);
  }
</style>
