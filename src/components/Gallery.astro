---
interface GalleryItem {
  src: string;
  alt: string;
  caption?: string;
}

const PHOTOS: GalleryItem[] = [
  { src: "https://picsum.photos/seed/praiasancho/400/300", alt: "Praia paradisíaca", caption: "Praia do Sancho, PE" },
  { src: "https://picsum.photos/seed/chapada/400/520", alt: "Pôr do sol no cerrado", caption: "Chapada dos Veadeiros, GO" },
  { src: "https://picsum.photos/seed/cristoredentor/400/280", alt: "Cristo Redentor", caption: "Rio de Janeiro, RJ" },
  { src: "https://picsum.photos/seed/iguacu/400/540", alt: "Cachoeira", caption: "Foz do Iguaçu, PR" },
  { src: "https://picsum.photos/seed/amazonia/400/480", alt: "Amazônia", caption: "Floresta Amazônica, AM" },
  { src: "https://picsum.photos/seed/salvadorba/400/320", alt: "Pelourinho", caption: "Salvador, BA" },
];
---

<section id="galeria" class="gallery-section" aria-labelledby="gallery-title">
  <div class="container">
    <header class="section-header">
      <h2 id="gallery-title" class="section-title">Galeria de Fotos</h2>
      <p class="section-subtitle">Belezas do Brasil em cada clique</p>
    </header>

    <div class="gallery-grid">
      {PHOTOS.map((photo) => (
        <a
          href={photo.src.replace(/\/\d+(\/\d+)?$/, '/800')}
          class="gallery-item"
          target="_blank"
          rel="noopener"
          aria-label={photo.alt}
        >
          <img src={photo.src} alt={photo.alt} loading="lazy" />
          {photo.caption && (
            <div class="gallery-caption">
              <span>{photo.caption}</span>
            </div>
          )}
        </a>
      ))}
    </div>
  </div>
</section>

<style is:global>
  .gallery-section {
    padding: var(--space-10) 0;
    background: var(--color-surface);
  }

  .gallery-grid {
    column-count: 3;
    column-gap: var(--space-2);
  }

  @media (max-width: 768px) {
    .gallery-grid { column-count: 2; }
  }

  @media (max-width: 480px) {
    .gallery-grid { column-count: 1; }
  }

  .gallery-item {
    position: relative;
    overflow: hidden;
    border-radius: var(--radius-md);
    display: block;
    margin-bottom: var(--space-2);
    break-inside: avoid;
    transition: all var(--duration-base) var(--ease-spring);
  }
  .gallery-item:hover {
    transform: scale(1.03) translateY(-2px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.15);
    text-decoration: none;
  }

  .gallery-item img {
    width: 100%;
    display: block;
    transition: transform var(--duration-slow) var(--ease-out-quart);
  }
  .gallery-item:hover img {
    transform: scale(1.08);
  }

  .gallery-caption {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: var(--space-2) var(--space-3);
    background: linear-gradient(transparent, rgba(0,0,0,0.7));
    color: white;
    font-size: var(--text-xs);
    font-weight: var(--weight-medium);
    opacity: 0;
    transition: opacity var(--duration-base) var(--ease-out-quart);
  }
  .gallery-item:hover .gallery-caption {
    opacity: 1;
  }
</style>
