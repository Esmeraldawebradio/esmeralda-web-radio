---
// Coordenadas do Brasil (centro: Brasília). O usuario pode trocar depois.
const LAT = -15.7934;
const LON = -47.8822;
const CITY = "Brasília";
---

<section id="clima" class="weather-section" aria-labelledby="weather-title">
  <div class="container">
    <header class="section-header">
      <h2 id="weather-title" class="section-title">Previsão do Tempo</h2>
      <p class="section-subtitle">Acompanhe as condições climáticas para os próximos dias</p>
    </header>

    <div id="weather-root" class="weather-root">
      <div class="weather-loading" aria-label="Carregando previsão do tempo...">
        <div class="spinner"></div>
        <span>Carregando previsão...</span>
      </div>
    </div>
  </div>
</section>

<script is:inline define:vars={{ WEATHER_LAT: LAT, WEATHER_LON: LON, WEATHER_CITY: CITY }}>
(async function() {
  const root = document.getElementById('weather-root');
  if (!root) return;

  const LAT = WEATHER_LAT;
  const LON = WEATHER_LON;
  const CITY = WEATHER_CITY;
  const DAYS = ['Dom', 'Seg', 'Ter', 'Qua', 'Qui', 'Sex', 'Sáb'];
  const WMO = {
    0: { icon: '☀️', label: 'Céu limpo' },
    1: { icon: '🌤️', label: 'Predomínio de sol' },
    2: { icon: '⛅', label: 'Parcialmente nublado' },
    3: { icon: '☁️', label: 'Nublado' },
    45: { icon: '🌫️', label: 'Nevoeiro' },
    48: { icon: '🌫️', label: 'Nevoeiro' },
    51: { icon: '🌦️', label: 'Chuva leve' },
    53: { icon: '🌦️', label: 'Chuva moderada' },
    55: { icon: '🌧️', label: 'Chuva forte' },
    61: { icon: '🌧️', label: 'Chuva' },
    63: { icon: '🌧️', label: 'Chuva moderada' },
    65: { icon: '🌧️', label: 'Chuva forte' },
    71: { icon: '🌨️', label: 'Neve' },
    80: { icon: '🌦️', label: 'Pancadas de chuva' },
    95: { icon: '⛈️', label: 'Tempestade' },
  };

  try {
    const res = await fetch(
      `https://api.open-meteo.com/v1/forecast?latitude=${LAT}&longitude=${LON}&daily=temperature_2m_max,temperature_2m_min,precipitation_probability_max,weathercode&timezone=America/Sao_Paulo&forecast_days=8`
    );
    if (!res.ok) throw new Error('API error');
    const data = await res.json();
    const days = data.daily;

    function getDayName(offset) {
      const d = new Date(days.time[offset]);
      return DAYS[d.getDay()];
    }

    function getDateStr(offset) {
      const d = new Date(days.time[offset]);
      return `${String(d.getDate()).padStart(2,'0')}/${String(d.getMonth()+1).padStart(2,'0')}`;
    }

    const forecast = days.time.map((_, i) => ({
      day: getDayName(i),
      date: getDateStr(i),
      code: days.weathercode[i],
      tempMax: Math.round(days.temperature_2m_max[i]),
      tempMin: Math.round(days.temperature_2m_min[i]),
      rain: days.precipitation_probability_max[i] || 0,
    }));

    const today = forecast[0];
    const wmo = WMO[today.code] || { icon: '🌤️', label: 'Estável' };

    root.innerHTML = `
      <div class="weather-today glass">
        <div class="weather-today-main">
          <span class="weather-icon-today">${wmo.icon}</span>
          <div class="weather-today-info">
            <span class="weather-temp-today">${today.tempMax}°C</span>
            <span class="weather-condition">${wmo.label}</span>
            <span class="weather-location">📍 ${CITY}</span>
          </div>
        </div>
        <div class="weather-today-details">
          <div class="weather-detail">
            <span class="detail-label">Mín</span>
            <span class="detail-value">${today.tempMin}°C</span>
          </div>
          <div class="weather-detail">
            <span class="detail-label">Máx</span>
            <span class="detail-value">${today.tempMax}°C</span>
          </div>
          <div class="weather-detail">
            <span class="detail-label">Chuva</span>
            <span class="detail-value">${today.rain}%</span>
          </div>
        </div>
      </div>
      <div class="weather-week">
        ${forecast.slice(1).map(d => {
          const w = WMO[d.code] || { icon: '🌤️', label: '' };
          return `
            <div class="weather-day glass clickable" role="button" tabindex="0">
              <span class="day-name">${d.day}</span>
              <span class="day-date">${d.date}</span>
              <span class="day-icon">${w.icon}</span>
              <span class="day-temps">
                <span class="day-max">${d.tempMax}°</span>
                <span class="day-min">${d.tempMin}°</span>
              </span>
              <div class="day-rain-bar" aria-label="Chuva ${d.rain}%">
                <div class="rain-fill" style="width:${d.rain}%"></div>
              </div>
              <span class="day-condition">${w.label}</span>
            </div>
          `;
        }).join('')}
      </div>
    `;
  } catch (e) {
    root.innerHTML = '<p style="text-align:center;color:var(--color-ink-muted);padding:var(--space-8)">Previsão temporariamente indisponível. Tente novamente mais tarde.</p>';
  }
})();
</script>

<style>
  .weather-section {
    padding: var(--space-16) 0;
  }

  .weather-root { min-height: 200px; }

  .weather-loading {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-12);
    color: var(--color-ink-muted);
    font-size: var(--text-sm);
  }

  .spinner {
    width: 32px;
    height: 32px;
    border: 3px solid var(--color-border);
    border-top-color: var(--color-primary);
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
  }

  @keyframes spin { to { transform: rotate(360deg); } }

  .weather-today {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-6) var(--space-8);
    margin-bottom: var(--space-6);
    gap: var(--space-6);
    flex-wrap: wrap;
  }

  .weather-today-main {
    display: flex;
    align-items: center;
    gap: var(--space-4);
  }

  .weather-icon-today { font-size: 4rem; line-height: 1; }

  .weather-today-info {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .weather-temp-today {
    font-size: 3rem;
    font-weight: var(--weight-bold);
    color: var(--color-primary);
    line-height: 1.1;
  }

  .weather-condition {
    font-size: var(--text-lg);
    color: var(--color-ink-muted);
    font-weight: var(--weight-medium);
  }

  .weather-location {
    font-size: var(--text-sm);
    color: var(--color-ink-subtle);
  }

  .weather-today-details {
    display: flex;
    gap: var(--space-6);
  }

  .weather-detail {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
  }

  .detail-label {
    font-size: var(--text-xs);
    color: var(--color-ink-subtle);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .detail-value {
    font-size: var(--text-lg);
    font-weight: var(--weight-bold);
    color: var(--color-ink);
  }

  .weather-week {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: var(--space-3);
  }

  @media (max-width: 768px) {
    .weather-week { grid-template-columns: repeat(3, 1fr); }
    .weather-today { flex-direction: column; text-align: center; }
    .weather-today-main { flex-direction: column; }
    .weather-today-details { justify-content: center; }
  }

  @media (max-width: 480px) {
    .weather-week { grid-template-columns: repeat(2, 1fr); }
  }

  .weather-day {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-4);
    text-align: center;
    transition: all var(--duration-base) var(--ease-spring);
  }
  .weather-day:hover {
    transform: translateY(-4px) scale(1.04);
    box-shadow: 0 8px 30px rgba(0,0,0,0.12);
  }

  .day-name {
    font-size: var(--text-sm);
    font-weight: var(--weight-bold);
    color: var(--color-ink);
    text-transform: uppercase;
  }

  .day-date {
    font-size: var(--text-xs);
    color: var(--color-ink-subtle);
  }

  .day-icon { font-size: 2rem; }

  .day-temps {
    display: flex;
    gap: var(--space-2);
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
  }

  .day-max { color: var(--color-primary); }
  .day-min { color: var(--color-ink-subtle); }

  .day-rain-bar {
    width: 100%;
    height: 4px;
    background: var(--color-border);
    border-radius: 9999px;
    overflow: hidden;
  }

  .rain-fill {
    height: 100%;
    background: linear-gradient(90deg, #4fc3f7, #1565c0);
    border-radius: 9999px;
    transition: width var(--duration-slow) var(--ease-out-quart);
  }

  .day-condition {
    font-size: var(--text-xs);
    color: var(--color-ink-muted);
  }
</style>
