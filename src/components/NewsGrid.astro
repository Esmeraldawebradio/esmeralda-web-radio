---
const CAT: Record<string, { label: string; color: string }> = {
  brazil: { label: 'Brasil', color: '#c06000' },
  world: { label: 'Mundo', color: '#6000a0' },
  economy: { label: 'Economia', color: '#2d7d46' },
  politics: { label: 'Política', color: '#c04020' },
  technology: { label: 'Tecnologia', color: '#1565c0' },
  science: { label: 'Ciência', color: '#008080' },
  health: { label: 'Saúde', color: '#c06000' },
  sports: { label: 'Esportes', color: '#e0a000' },
  entertainment: { label: 'Entretenimento', color: '#802000' },
  culture: { label: 'Cultura', color: '#6000a0' },
  climate: { label: 'Clima', color: '#4a8aff' },
};

function catInfo(c: string) { return CAT[c] || { label: c, color: '#555' }; }

function timeAgo(s: string) {
  const diff = Math.floor((Date.now() - new Date(s).getTime()) / 1000);
  if (diff < 60) return 'agora';
  if (diff < 3600) return Math.floor(diff / 60) + 'min';
  if (diff < 86400) return Math.floor(diff / 3600) + 'h';
  if (diff < 172800) return 'ontem';
  return Math.floor(diff / 86400) + 'd';
}

async function fetchOgImage(url: string): Promise<string | null> {
  try {
    const controller = new AbortController();
    const timeout = setTimeout(() => controller.abort(), 5000);
    const res = await fetch(url, { signal: controller.signal });
    clearTimeout(timeout);
    if (!res.ok) return null;
    const html = await res.text();
    const m = html.match(/<meta\s+property=["']og:image["']\s+content=["']([^"']+)["']/i)
           || html.match(/<meta\s+content=["']([^"']+)["']\s+property=["']og:image["']/i);
    return m ? m[1] : null;
  } catch {
    return null;
  }
}

function cardHTML(item: any, i: number, isFeatured: boolean, imgSrc: string) {
  const cat = catInfo(item.categories?.[0] || 'brazil');
  const outlets = item.outlets?.map((o: any) => o.name).join(', ') || 'Daily Journal';
  const feat = isFeatured ? ' featured' : '';
  return `
    <a href="${item.url}" class="news-card${feat} stagger-item" target="_blank" rel="noopener" style="--news-color:${cat.color};--i:${i}">
      <div class="news-card-img">
        <img src="${imgSrc}" alt="${item.title}" loading="lazy">
        <div class="news-card-img-overlay"></div>
        <span class="news-card-badge">${cat.label}</span>
      </div>
      <div class="news-card-body">
        <div class="news-card-meta"><span class="news-card-time">${timeAgo(item.published_at)}</span><span class="news-card-source">${outlets}</span></div>
        <h3 class="news-card-title">${item.title}</h3>
        <p class="news-card-summary">${item.description}</p>
        <span class="news-card-more">Ler matéria →</span>
      </div>
    </a>`;
}

function fallbackHTML() {
  const items = [
    { title: "Brasil registra avanço em indicadores econômicos", description: "Dados do Banco Central mostram recuperação consistente da atividade econômica em todas as regiões do país.", cat: "economy" },
    { title: "Cúpula do clima reúne líderes de 50 países em Brasília", description: "Encontro debate metas de redução de carbono e financiamento para energias renováveis.", cat: "world" },
    { title: "Tecnologia brasileira ganha destaque em feira internacional", description: "Startups do país apresentam soluções inovadoras em inteligência artificial e agronegócio.", cat: "technology" },
    { title: "Novo programa de saúde amplia atendimento no SUS", description: "Ministério da Saúde anuncia investimento recorde na atenção primária para comunidades rurais.", cat: "health" },
    { title: "Festival de cinema nacional bate recorde de público", description: "Mostra de filmes brasileiros atrai milhares de espectadores e impulsiona o cinema nacional.", cat: "culture" },
    { title: "Campeonato nacional tem rodada decisiva", description: "Clássicos regionais agitam a tabela e definem os primeiros classificados para a fase final.", cat: "sports" },
  ];
  return items.map((item, i) => {
    const cat = catInfo(item.cat);
    return `
      <a href="#" class="news-card stagger-item" style="--news-color:${cat.color};--i:${i}">
        <div class="news-card-img">
          <img src="https://picsum.photos/seed/fb${i}/600/400" alt="" loading="lazy">
          <div class="news-card-img-overlay"></div>
          <span class="news-card-badge">${cat.label}</span>
        </div>
        <div class="news-card-body">
          <div class="news-card-meta"><span class="news-card-time">—</span></div>
          <h3 class="news-card-title">${item.title}</h3>
          <p class="news-card-summary">${item.description}</p>
        </div>
      </a>`;
  }).join('');
}

let serverHTML = '';
try {
  const res = await fetch('https://dailyjournal.news/api/public/news?limit=6');
  if (res.ok) {
    const data = await res.json();
    const items = data.items || [];
    const cards = await Promise.all(items.map(async (item: any, i: number) => {
      let img = item.image_url || null;
      if (!img) img = await fetchOgImage(item.url);
      if (!img) img = `https://picsum.photos/seed/${item.slug || 'n' + i}/600/400`;
      return cardHTML(item, i, i === 0, img);
    }));
    serverHTML = `<div class="news-grid">${cards.join('')}</div>
      <p class="news-footer">Agregado por Daily Journal · G1, Folha, UOL, CNN Brasil e mais</p>`;
  }
} catch (e) {
  // fallback to client-side
}
---

<section id="noticias" class="section-padded section-surface" aria-labelledby="news-title">
  <div class="container">
    <header class="section-header">
      <h2 id="news-title" class="section-title">Notícias</h2>
      <p class="section-subtitle">Os principais acontecimentos do Brasil e do mundo</p>
    </header>

    <div id="news-root" class="news-root">
      {serverHTML ? (
        <Fragment set:html={serverHTML} />
      ) : (
        <>
          <div class="loading-root" aria-label="Carregando notícias...">
            <div class="spinner"></div>
            <span>Carregando notícias...</span>
          </div>
          <script is:inline>
(function(){const r=document.getElementById('news-root');if(!r)return;
const CAT={brazil:{label:'Brasil',color:'#c06000'},world:{label:'Mundo',color:'#6000a0'},economy:{label:'Economia',color:'#2d7d46'},politics:{label:'Política',color:'#c04020'},technology:{label:'Tecnologia',color:'#1565c0'},science:{label:'Ciência',color:'#008080'},health:{label:'Saúde',color:'#c06000'},sports:{label:'Esportes',color:'#e0a000'},entertainment:{label:'Entretenimento',color:'#802000'},culture:{label:'Cultura',color:'#6000a0'},climate:{label:'Clima',color:'#4a8aff'}};
function ci(c){return CAT[c]||{label:c,color:'#555'};}
function ta(s){const d=Math.floor((Date.now()-new Date(s).getTime())/1e3);return d<60?'agora':d<3600?Math.floor(d/60)+'min':d<86400?Math.floor(d/3600)+'h':d<172800?'ontem':Math.floor(d/86400)+'d';}
function ch(item,i,feat){const c=ci(item.categories?.[0]||'brazil'),o=item.outlets?.map(o=>o.name).join(', ')||'Daily Journal',src='https://picsum.photos/seed/'+(item.slug||'n'+i)+'/600/400',f=feat?' featured':'';return '<a href="'+item.url+'" class="news-card'+f+' stagger-item" target="_blank" rel="noopener" style="--news-color:'+c.color+';--i:'+i+'"><div class="news-card-img"><img src="'+src+'" alt="'+item.title+'" loading="lazy"><div class="news-card-img-overlay"></div><span class="news-card-badge">'+c.label+'</span></div><div class="news-card-body"><div class="news-card-meta"><span class="news-card-time">'+ta(item.published_at)+'</span><span class="news-card-source">'+o+'</span></div><h3 class="news-card-title">'+item.title+'</h3><p class="news-card-summary">'+item.description+'</p><span class="news-card-more">Ler matéria →</span></div></a>';}
function fb(){const items=[{title:"Brasil registra avanço em indicadores econômicos",description:"Dados do Banco Central mostram recuperação consistente da atividade econômica em todas as regiões do país.",cat:"economy"},{title:"Cúpula do clima reúne líderes de 50 países em Brasília",description:"Encontro debate metas de redução de carbono e financiamento para energias renováveis.",cat:"world"},{title:"Tecnologia brasileira ganha destaque em feira internacional",description:"Startups do país apresentam soluções inovadoras em inteligência artificial e agronegócio.",cat:"technology"},{title:"Novo programa de saúde amplia atendimento no SUS",description:"Ministério da Saúde anuncia investimento recorde na atenção primária para comunidades rurais.",cat:"health"},{title:"Festival de cinema nacional bate recorde de público",description:"Mostra de filmes brasileiros atrai milhares de espectadores e impulsiona o cinema nacional.",cat:"culture"},{title:"Campeonato nacional tem rodada decisiva",description:"Clássicos regionais agitam a tabela e definem os primeiros classificados para a fase final.",cat:"sports"}];return items.map((item,i)=>{const c=ci(item.cat);return '<a href="#" class="news-card stagger-item" style="--news-color:'+c.color+';--i:'+i+'"><div class="news-card-img"><img src="https://picsum.photos/seed/fb'+i+'/600/400" alt="" loading="lazy"><div class="news-card-img-overlay"></div><span class="news-card-badge">'+c.label+'</span></div><div class="news-card-body"><div class="news-card-meta"><span class="news-card-time">—</span></div><h3 class="news-card-title">'+item.title+'</h3><p class="news-card-summary">'+item.description+'</p></div></a>';}).join('');}
async function load(){try{const p=await fetch('https://dailyjournal.news/api/public/news?limit=6');if(!p.ok)throw Error();const j=await p.json(),items=j.items||[];r.innerHTML='<div class="news-grid">'+items.map((item,i)=>ch(item,i,i===0)).join('')+'</div><p class="news-footer">Agregado por Daily Journal · G1, Folha, UOL, CNN Brasil e mais</p>';}catch(e){r.innerHTML='<div class="news-grid">'+fb()+'</div>';}}
load();})();
          </script>
        </>
      )}
    </div>
  </div>
</section>

<style is:global>
  .news-root { min-height: 200px; }

  .news-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-3); }
  @media (max-width: 768px) { .news-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 480px) { .news-grid { grid-template-columns: 1fr; } }

  .news-card {
    display: flex; flex-direction: column; overflow: hidden;
    text-decoration: none; color: inherit;
    transition: all var(--duration-base) var(--ease-spring);
    border-top: 3px solid var(--news-color, var(--color-primary));
  }
  .news-card:hover { transform: translateY(-4px); box-shadow: 0 12px 32px rgba(0,0,0,0.12); text-decoration: none; }
  .news-card.featured { border-top-width: 4px; }
  .news-card.featured .news-card-title { font-size: var(--text-base); }

  .news-card-img { position: relative; width: 100%; height: 140px; overflow: hidden; }
  .news-card-img img { width: 100%; height: 100%; object-fit: cover; transition: transform var(--duration-slow) var(--ease-out-quart); }
  .news-card:hover .news-card-img img { transform: scale(1.08); }

  .news-card-img-overlay { position: absolute; inset: 0; background: linear-gradient(180deg, transparent 60%, rgba(0,0,0,0.4)); pointer-events: none; }
  .news-card-badge {
    position: absolute; top: var(--space-3); left: var(--space-3);
    padding: 3px 12px; border-radius: 9999px;
    font-size: 11px; font-weight: var(--weight-bold); color: white;
    text-transform: uppercase; letter-spacing: 0.05em;
    background: var(--news-color, var(--color-primary));
  }

  .news-card-body {
    padding: var(--space-3); flex: 1;
    display: flex; flex-direction: column; gap: var(--space-1);
    background: var(--color-surface-elevated);
  }

  .news-card-meta { display: flex; gap: var(--space-2); font-size: 10px; color: var(--color-ink-subtle); }
  .news-card-time, .news-card-source { display: inline-flex; align-items: center; }
  .news-card-time::after { content: '·'; margin-left: var(--space-2); opacity: 0.5; }
  .news-card-source { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

  .news-card-title {
    font-size: var(--text-sm); font-weight: var(--weight-bold);
    color: var(--color-ink); line-height: var(--leading-snug);
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
  }
  .news-card-summary {
    font-size: var(--text-sm); color: var(--color-ink-muted);
    line-height: var(--leading-normal);
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
  }
  .news-card-more { font-size: var(--text-sm); font-weight: var(--weight-semibold); color: var(--news-color, var(--color-primary)); margin-top: auto; }

  .news-footer { text-align: center; margin-top: var(--space-4); font-size: var(--text-xs); color: var(--color-ink-subtle); }
  .news-card.stagger-item { animation-delay: calc(var(--i, 0) * 60ms); }
</style>
