---
---

<section id="noticias" class="news-section" aria-labelledby="news-title">
  <div class="container">
    <header class="section-header">
      <h2 id="news-title" class="section-title">Notícias</h2>
      <p class="section-subtitle">Os principais acontecimentos do Brasil e do mundo</p>
    </header>

    <div id="news-root" class="news-root">
      <div class="news-loading" aria-label="Carregando notícias...">
        <div class="spinner"></div>
        <span>Carregando notícias...</span>
      </div>
    </div>
  </div>
</section>

<script is:inline>
(async function() {
  const root = document.getElementById('news-root');
  if (!root) return;

  function timeAgo(dateStr) {
    const now = new Date();
    const date = new Date(dateStr);
    const diff = Math.floor((now - date) / 1000);
    if (diff < 60) return 'agora';
    if (diff < 3600) return `${Math.floor(diff / 60)}min`;
    if (diff < 86400) return `${Math.floor(diff / 3600)}h`;
    if (diff < 172800) return 'ontem';
    return `${Math.floor(diff / 86400)}d`;
  }

  function categoryLabel(cat) {
    const map = {
      brazil: 'Brasil',
      world: 'Mundo',
      economy: 'Economia',
      politics: 'Política',
      technology: 'Tecnologia',
      science: 'Ciência',
      health: 'Saúde',
      sports: 'Esportes',
      entertainment: 'Entretenimento',
      culture: 'Cultura',
      climate: 'Clima',
    };
    return map[cat] || cat;
  }

  function categoryColor(cat) {
    const map = {
      brazil: '#c06000',
      world: '#6000a0',
      economy: '#2d7d46',
      politics: '#c04020',
      technology: '#1565c0',
      science: '#008080',
      health: '#c06000',
      sports: '#e0a000',
      entertainment: '#802000',
      culture: '#6000a0',
    };
    return map[cat] || '#555';
  }

  try {
    const res = await fetch('https://dailyjournal.news/api/public/news?limit=6');
    if (!res.ok) throw new Error('API error');
    const data = await res.json();
    const items = data.items || [];

    root.innerHTML = `
      <div class="news-grid">
        ${items.map((item, i) => {
          const cat = item.categories?.[0] || 'brazil';
          const outlets = item.outlets?.map(o => o.name).join(', ') || 'Daily Journal';
          const imageSeed = item.slug || `news${i}`;
          const isFeatured = i === 0;

          return `
            <a href="${item.url}" class="news-card glass clickable ${isFeatured ? 'featured' : ''}" target="_blank" rel="noopener" style="--cat-color: ${categoryColor(cat)}">
              <div class="news-image">
                <img src="https://picsum.photos/seed/${imageSeed}/600/400" alt="${item.title}" loading="lazy">
                <div class="news-image-overlay"></div>
                <span class="news-badge" style="background: ${categoryColor(cat)}">${categoryLabel(cat)}</span>
              </div>
              <div class="news-body">
                <div class="news-meta">
                  <span class="news-time">${timeAgo(item.published_at)}</span>
                  <span class="news-source">${outlets}</span>
                </div>
                <h3 class="news-title">${item.title}</h3>
                <p class="news-summary">${item.description}</p>
                <span class="news-read-more">Ler matéria →</span>
              </div>
            </a>
          `;
        }).join('')}
      </div>
      <p class="news-footer">Agregado por Daily Journal · Fontes: G1, Folha, UOL, CNN Brasil e mais</p>
    `;
  } catch (e) {
    root.innerHTML = `
      <div class="news-grid">
        ${[
          { title: "Brasil registra avanço em indicadores econômicos no segundo trimestre", description: "Dados do Banco Central mostram recuperação consistente da atividade econômica em todas as regiões do país.", cat: "economy" },
          { title: "Cúpula do clima em Brasília reúne líderes de 50 países", description: "Encontro debate metas de redução de carbono e financiamento para energias renováveis na América Latina.", cat: "world" },
          { title: "Tecnologia brasileira ganha destaque em feira internacional", description: "Startups do país apresentam soluções inovadoras em inteligência artificial e agronegócio.", cat: "technology" },
          { title: "Novo programa de saúde amplia atendimento no SUS", description: "Ministério da Saúde anuncia investimento recorde na atenção primária para comunidades rurais.", cat: "health" },
          { title: "Festival de cinema nacional bate recorde de público", description: "Mostra de filmes brasileiros atrai milhares de espectadores e impulsiona o cinema nacional.", cat: "culture" },
          { title: "Campeonato nacional de futebol tem rodada decisiva", description: "Clássicos regionais agitam a tabela e definem os primeiros classificados para a fase final.", cat: "sports" },
        ].map((item, i) => `
          <a href="#" class="news-card glass clickable" style="--cat-color: ${categoryColor(item.cat)}">
            <div class="news-image">
              <img src="https://picsum.photos/seed/fallback${i}/600/400" alt="${item.title}" loading="lazy">
              <div class="news-image-overlay"></div>
              <span class="news-badge" style="background: ${categoryColor(item.cat)}">${categoryLabel(item.cat)}</span>
            </div>
            <div class="news-body">
              <div class="news-meta">
                <span class="news-time">—</span>
              </div>
              <h3 class="news-title">${item.title}</h3>
              <p class="news-summary">${item.description}</p>
            </div>
          </a>
        `).join('')}
      </div>
    `;
  }
})();
</script>

<style>
  .news-section { padding: var(--space-16) 0; background: var(--color-surface); }
  .news-root { min-height: 200px; }

  .news-loading {
    display: flex; flex-direction: column; align-items: center;
    gap: var(--space-3); padding: var(--space-12);
    color: var(--color-ink-muted); font-size: var(--text-sm);
  }

  .spinner {
    width: 32px; height: 32px;
    border: 3px solid var(--color-border);
    border-top-color: var(--color-primary);
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
  }

  @keyframes spin { to { transform: rotate(360deg); } }

  .news-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-5);
  }

  @media (max-width: 768px) {
    .news-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 480px) {
    .news-grid { grid-template-columns: 1fr; }
  }

  .news-card {
    display: flex;
    flex-direction: column;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: all var(--duration-base) var(--ease-spring);
    border-top: 3px solid var(--cat-color, var(--color-primary));
  }
  .news-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 16px 48px rgba(0,0,0,0.15);
    text-decoration: none;
  }
  .news-card.featured {
    grid-column: 1 / -1;
    display: grid;
    grid-template-columns: 1fr 1fr;
  }

  @media (max-width: 640px) {
    .news-card.featured { grid-template-columns: 1fr; }
  }

  .news-image {
    position: relative;
    width: 100%;
    height: 200px;
    overflow: hidden;
  }
  .news-card.featured .news-image { height: 280px; }
  .news-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--duration-slow) var(--ease-out-quart);
  }
  .news-card:hover .news-image img { transform: scale(1.08); }

  .news-image-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 60%, rgba(0,0,0,0.4));
    pointer-events: none;
  }

  .news-badge {
    position: absolute;
    top: var(--space-3);
    left: var(--space-3);
    padding: 3px 12px;
    border-radius: 9999px;
    font-size: 11px;
    font-weight: var(--weight-bold);
    color: white;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .news-body {
    padding: var(--space-4);
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    background: var(--color-surface-elevated);
  }

  .news-meta {
    display: flex;
    gap: var(--space-2);
    font-size: 11px;
    color: var(--color-ink-subtle);
  }

  .news-time, .news-source {
    display: inline-flex;
    align-items: center;
  }

  .news-time::after {
    content: '·';
    margin-left: var(--space-2);
    opacity: 0.5;
  }

  .news-source {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .news-title {
    font-size: var(--text-base);
    font-weight: var(--weight-bold);
    color: var(--color-ink);
    line-height: var(--leading-snug);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .news-summary {
    font-size: var(--text-sm);
    color: var(--color-ink-muted);
    line-height: var(--leading-normal);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .news-read-more {
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    color: var(--cat-color, var(--color-primary));
    margin-top: auto;
  }

  .news-footer {
    text-align: center;
    margin-top: var(--space-4);
    font-size: var(--text-xs);
    color: var(--color-ink-subtle);
  }
</style>
