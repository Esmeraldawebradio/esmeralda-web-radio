---
const NEWS = [
  {
    region: "Norte",
    title: "Manaus registra menor nível do Rio Negro em 120 anos",
    summary: "Secas históricas afetam transporte e comunidades ribeirinhas na Amazônia.",
    image: "https://images.unsplash.com/photo-1618005182384-a83a8bd57fbe?w=600&q=80",
    link: "#"
  },
  {
    region: "Nordeste",
    title: "Salvador bate recorde de turistas no verão 2026",
    summary: "Capital baiana recebe mais de 2 milhões de visitantes na alta temporada.",
    image: "https://images.unsplash.com/photo-1540541338287-41700207dee6?w=600&q=80",
    link: "#"
  },
  {
    region: "Centro-Oeste",
    title: "Brasília sedia cúpula internacional do clima",
    summary: "Líderes mundiais discutem metas ambientais para a próxima década.",
    image: "https://images.unsplash.com/photo-1574484284002-952d92456975?w=600&q=80",
    link: "#"
  },
  {
    region: "Sudeste",
    title: "São Paulo inaugura maior parque linear da América Latina",
    summary: "Espaço verde de 12km conecta bairros e estimula mobilidade sustentável.",
    image: "https://images.unsplash.com/photo-1569336415962-a4bd9f18cdb3?w=600&q=80",
    link: "#"
  },
  {
    region: "Sul",
    title: "SC lidera geração de energia eólica no país",
    summary: "Parques offshore prometem dobrar capacidade nos próximos 5 anos.",
    image: "https://images.unsplash.com/photo-1532601224476-15c79f2f7a51?w=600&q=80",
    link: "#"
  },
  {
    region: "Nordeste",
    title: "Recife investe em tecnologia contra enchentes",
    summary: "Sistema de alerta inteligente usa IA para prever alagamentos.",
    image: "https://images.unsplash.com/photo-1569154941061-e231b4725ef1?w=600&q=80",
    link: "#"
  }
];
const REGION_COLORS = {
  "Norte": "#2d7d46",
  "Nordeste": "#c06000",
  "Centro-Oeste": "#e0a000",
  "Sudeste": "#6000a0",
  "Sul": "#002040",
};
---

<section id="noticias" class="news-section" aria-labelledby="news-title">
  <div class="container">
    <header class="section-header">
      <h2 id="news-title" class="section-title">Notícias do Brasil</h2>
      <p class="section-subtitle">De Norte a Sul, os principais acontecimentos de cada região</p>
    </header>

    <div class="news-grid">
      {NEWS.map((item) => (
        <a href={item.link} class="news-card glass clickable" target="_blank" rel="noopener">
          <div class="news-image">
            <img src={item.image} alt={item.title} loading="lazy" />
            <span class="news-region" style={`background:${REGION_COLORS[item.region]}`}>{item.region}</span>
          </div>
          <div class="news-body">
            <h3 class="news-title">{item.title}</h3>
            <p class="news-summary">{item.summary}</p>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .news-section {
    padding: var(--space-16) 0;
    background: var(--color-surface);
  }

  .news-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: var(--space-6);
  }

  .news-card {
    display: flex;
    flex-direction: column;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: all var(--duration-base) var(--ease-spring);
  }
  .news-card:hover {
    transform: translateY(-6px) scale(1.02);
    box-shadow: 0 12px 40px rgba(0,0,0,0.15);
    text-decoration: none;
  }

  .news-image {
    position: relative;
    width: 100%;
    height: 200px;
    overflow: hidden;
  }
  .news-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--duration-slow) var(--ease-out-quart);
  }
  .news-card:hover .news-image img {
    transform: scale(1.08);
  }

  .news-region {
    position: absolute;
    top: var(--space-3);
    left: var(--space-3);
    padding: 2px 12px;
    border-radius: 9999px;
    font-size: var(--text-xs);
    font-weight: var(--weight-bold);
    color: white;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .news-body {
    padding: var(--space-4);
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .news-title {
    font-size: var(--text-base);
    font-weight: var(--weight-bold);
    color: var(--color-ink);
    line-height: var(--leading-snug);
  }

  .news-summary {
    font-size: var(--text-sm);
    color: var(--color-ink-muted);
    line-height: var(--leading-normal);
  }
</style>
