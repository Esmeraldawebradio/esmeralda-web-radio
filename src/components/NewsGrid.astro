---
---

<section id="noticias" class="section-padded section-surface" aria-labelledby="news-title">
  <div class="container">
    <header class="section-header">
      <h2 id="news-title" class="section-title">Notícias</h2>
      <p class="section-subtitle">Os principais acontecimentos do Brasil e do mundo</p>
    </header>

    <div id="news-root" class="news-root">
      <div class="loading-root" aria-label="Carregando notícias...">
        <div class="spinner"></div>
        <span>Carregando notícias...</span>
      </div>
    </div>
  </div>
</section>

<script is:inline>
(function() {
  const root = document.getElementById('news-root');
  if (!root) return;

  const CAT = {
    brazil: { label: 'Brasil', color: '#c06000' },
    world: { label: 'Mundo', color: '#6000a0' },
    economy: { label: 'Economia', color: '#2d7d46' },
    politics: { label: 'Política', color: '#c04020' },
    technology: { label: 'Tecnologia', color: '#1565c0' },
    science: { label: 'Ciência', color: '#008080' },
    health: { label: 'Saúde', color: '#c06000' },
    sports: { label: 'Esportes', color: '#e0a000' },
    entertainment: { label: 'Entretenimento', color: '#802000' },
    culture: { label: 'Cultura', color: '#6000a0' },
    climate: { label: 'Clima', color: '#4a8aff' },
  };

  function catInfo(c) { return CAT[c] || { label: c, color: '#555' }; }

  function timeAgo(s) {
    const diff = Math.floor((Date.now() - new Date(s).getTime()) / 1000);
    if (diff < 60) return 'agora';
    if (diff < 3600) return Math.floor(diff / 60) + 'min';
    if (diff < 86400) return Math.floor(diff / 3600) + 'h';
    if (diff < 172800) return 'ontem';
    return Math.floor(diff / 86400) + 'd';
  }

  function cardHTML(item, i, isFeatured) {
    const cat = catInfo(item.categories?.[0] || 'brazil');
    const outlets = item.outlets?.map(o => o.name).join(', ') || 'Daily Journal';
    const src = `https://picsum.photos/seed/${item.slug||'n'+i}/600/400`;
    const feat = isFeatured ? ' featured' : '';
    return `
      <a href="${item.url}" class="nc${feat}" target="_blank" rel="noopener" style="--nc:${cat.color}">
        <div class="nc-img">
          <img src="${src}" alt="${item.title}" loading="lazy">
          <div class="nc-img-o"></div>
          <span class="nc-badge">${cat.label}</span>
        </div>
        <div class="nc-body">
          <div class="nc-meta"><span class="nc-time">${timeAgo(item.published_at)}</span><span class="nc-src">${outlets}</span></div>
          <h3 class="nc-title">${item.title}</h3>
          <p class="nc-summary">${item.description}</p>
          <span class="nc-more">Ler matéria →</span>
        </div>
      </a>`;
  }

  function fallbackHTML() {
    const items = [
      { title: "Brasil registra avanço em indicadores econômicos", description: "Dados do Banco Central mostram recuperação consistente da atividade econômica em todas as regiões do país.", cat: "economy" },
      { title: "Cúpula do clima reúne líderes de 50 países em Brasília", description: "Encontro debate metas de redução de carbono e financiamento para energias renováveis.", cat: "world" },
      { title: "Tecnologia brasileira ganha destaque em feira internacional", description: "Startups do país apresentam soluções inovadoras em inteligência artificial e agronegócio.", cat: "technology" },
      { title: "Novo programa de saúde amplia atendimento no SUS", description: "Ministério da Saúde anuncia investimento recorde na atenção primária para comunidades rurais.", cat: "health" },
      { title: "Festival de cinema nacional bate recorde de público", description: "Mostra de filmes brasileiros atrai milhares de espectadores e impulsiona o cinema nacional.", cat: "culture" },
      { title: "Campeonato nacional tem rodada decisiva", description: "Clássicos regionais agitam a tabela e definem os primeiros classificados para a fase final.", cat: "sports" },
    ];
    return items.map((item, i) => {
      const cat = catInfo(item.cat);
      return `
        <a href="#" class="nc" style="--nc:${cat.color}">
          <div class="nc-img">
            <img src="https://picsum.photos/seed/fb${i}/600/400" alt="" loading="lazy">
            <div class="nc-img-o"></div>
            <span class="nc-badge">${cat.label}</span>
          </div>
          <div class="nc-body">
            <div class="nc-meta"><span class="nc-time">—</span></div>
            <h3 class="nc-title">${item.title}</h3>
            <p class="nc-summary">${item.description}</p>
          </div>
        </a>`;
    }).join('');
  }

  async function load() {
    try {
      const res = await fetch('https://dailyjournal.news/api/public/news?limit=6');
      if (!res.ok) throw new Error();
      const data = await res.json();
      const items = data.items || [];
      root.innerHTML = `<div class="ng">${items.map((item, i) => cardHTML(item, i, i === 0)).join('')}</div>
        <p class="nf">Agregado por Daily Journal · G1, Folha, UOL, CNN Brasil e mais</p>`;
    } catch (e) {
      root.innerHTML = `<div class="ng">${fallbackHTML()}</div>`;
    }
  }

  load();
})();
</script>

<style>
  .news-root { min-height: 200px; }

  .ng { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-5); }
  @media (max-width: 768px) { .ng { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 480px) { .ng { grid-template-columns: 1fr; } }

  .nc {
    display: flex; flex-direction: column; overflow: hidden;
    text-decoration: none; color: inherit;
    transition: all var(--duration-base) var(--ease-spring);
    border-top: 3px solid var(--nc, var(--color-primary));
  }
  .nc:hover { transform: translateY(-6px); box-shadow: 0 16px 48px rgba(0,0,0,0.15); text-decoration: none; }
  .nc.featured { grid-column: 1 / -1; display: grid; grid-template-columns: 1fr 1fr; }
  @media (max-width: 640px) { .nc.featured { grid-template-columns: 1fr; } }

  .nc-img { position: relative; width: 100%; height: 200px; overflow: hidden; }
  .nc.featured .nc-img { height: 280px; }
  .nc-img img { width: 100%; height: 100%; object-fit: cover; transition: transform var(--duration-slow) var(--ease-out-quart); }
  .nc:hover .nc-img img { transform: scale(1.08); }

  .nc-img-o { position: absolute; inset: 0; background: linear-gradient(180deg, transparent 60%, rgba(0,0,0,0.4)); pointer-events: none; }
  .nc-badge {
    position: absolute; top: var(--space-3); left: var(--space-3);
    padding: 3px 12px; border-radius: 9999px;
    font-size: 11px; font-weight: var(--weight-bold); color: white;
    text-transform: uppercase; letter-spacing: 0.05em;
    background: var(--nc, var(--color-primary));
  }

  .nc-body {
    padding: var(--space-4); flex: 1;
    display: flex; flex-direction: column; gap: var(--space-2);
    background: var(--color-surface-elevated);
  }

  .nc-meta { display: flex; gap: var(--space-2); font-size: 11px; color: var(--color-ink-subtle); }
  .nc-time, .nc-src { display: inline-flex; align-items: center; }
  .nc-time::after { content: '·'; margin-left: var(--space-2); opacity: 0.5; }
  .nc-src { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

  .nc-title {
    font-size: var(--text-base); font-weight: var(--weight-bold);
    color: var(--color-ink); line-height: var(--leading-snug);
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
  }
  .nc-summary {
    font-size: var(--text-sm); color: var(--color-ink-muted);
    line-height: var(--leading-normal);
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
  }
  .nc-more { font-size: var(--text-sm); font-weight: var(--weight-semibold); color: var(--nc, var(--color-primary)); margin-top: auto; }

  .nf { text-align: center; margin-top: var(--space-4); font-size: var(--text-xs); color: var(--color-ink-subtle); }
</style>
