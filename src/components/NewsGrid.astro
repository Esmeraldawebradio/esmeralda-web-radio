---
import { NEWS_SOURCES } from '../config.ts';

const RSS2JSON = 'https://api.rss2json.com/v1/api.json';

interface NewsItem {
  title: string;
  description: string;
  url: string;
  image: string;
  published_at: string;
  source: string;
}

function timeAgo(s: string) {
  const diff = Math.floor((Date.now() - new Date(s).getTime()) / 1000);
  if (diff < 60) return 'agora';
  if (diff < 3600) return Math.floor(diff / 60) + 'min';
  if (diff < 86400) return Math.floor(diff / 3600) + 'h';
  if (diff < 172800) return 'ontem';
  return Math.floor(diff / 86400) + 'd';
}

const ENTITIES: Record<string, string> = {
  amp:'&',lt:'<',gt:'>',quot:'"',apos:"'",nbsp:'\u00A0',
  aacute:'á',eacute:'é',iacute:'í',oacute:'ó',uacute:'ú',yacute:'ý',
  agrave:'à',egrave:'è',igrave:'ì',ograve:'ò',ugrave:'ù',
  acirc:'â',ecirc:'ê',icirc:'î',ocirc:'ô',ucirc:'û',
  atilde:'ã',otilde:'õ',ntilde:'ñ',
  auml:'ä',euml:'ë',iuml:'ï',ouml:'ö',uuml:'ü',yuml:'ÿ',
  ccedil:'ç',
  Aacute:'Á',Eacute:'É',Iacute:'Í',Oacute:'Ó',Uacute:'Ú',Yacute:'Ý',
  Agrave:'À',Egrave:'È',Igrave:'Ì',Ograve:'Ò',Ugrave:'Ù',
  Acirc:'Â',Ecirc:'Ê',Icirc:'Î',Ocirc:'Ô',Ucirc:'Û',
  Atilde:'Ã',Otilde:'Õ',Ntilde:'Ñ',
  Auml:'Ä',Euml:'Ë',Iuml:'Ï',Ouml:'Ö',Uuml:'Ü',
  Ccedil:'Ç',szlig:'ß',
  ndash:'–',mdash:'—',lsquo:'\u2018',rsquo:'\u2019',ldquo:'\u201C',rdquo:'\u201D',
  bull:'•',hellip:'…',euro:'€',trade:'™',copy:'©',reg:'®',deg:'°',
  iexcl:'¡',iquest:'¿',laquo:'«',raquo:'»',sect:'§',para:'¶',
  times:'×',divide:'÷',permil:'‰',prime:'′',Prime:'″',
  dagger:'†',Dagger:'‡',sbquo:'‚',bdquo:'„',
};

function decodeEntities(s: string): string {
  return s.replace(/&#(\d+);/g, (_, n) => String.fromCodePoint(+n))
    .replace(/&#x([0-9a-f]+);/gi, (_, n) => String.fromCodePoint(parseInt(n, 16)))
    .replace(/&([a-zA-Z]+);/g, (_, n) => ENTITIES[n] || '&' + n + ';');
}

function cleanDesc(s: string): string {
  return decodeEntities(s.replace(/<[^>]*>/g, '')).replace(/\s+/g, ' ').trim().substring(0, 200);
}

function cardHTML(item: NewsItem, i: number, featured: boolean) {
  const cat = { label: 'Brasil', color: '#c06000' };
  return `
    <a href="${item.url}" class="news-card${featured ? ' featured' : ''} stagger-item" target="_blank" rel="noopener" style="--news-color:${cat.color};--i:${i}">
      <div class="news-card-img">
        <img src="${item.image}" alt="${item.title.replace(/"/g, '&quot;')}" loading="lazy" onerror="this.parentElement.classList.add('news-card-img--empty')">
        <div class="news-card-img-overlay"></div>
        <span class="news-card-badge">${item.source}</span>
      </div>
      <div class="news-card-body">
        <div class="news-card-meta"><span class="news-card-time">${timeAgo(item.published_at)}</span><span class="news-card-source">${item.source}</span></div>
        <h3 class="news-card-title">${item.title}</h3>
        <p class="news-card-summary">${item.description || ''}</p>
        <span class="news-card-more">Ler matéria →</span>
      </div>
    </a>`;
}

let serverHTML = '';
try {
  const allItems: NewsItem[] = [];
  const usedTitles = new Set<string>();

  for (const source of NEWS_SOURCES) {
    try {
      const controller = new AbortController();
      const timeout = setTimeout(() => controller.abort(), 5000);
      const url = `${RSS2JSON}?rss_url=${encodeURIComponent(source.feedUrl)}`;
      const res = await fetch(url, { signal: controller.signal });
      clearTimeout(timeout);
      if (!res.ok) continue;
      const data = await res.json();
      if (data.status !== 'ok' || !data.items) continue;
      for (const item of data.items) {
        const title = item.title || '';
        if (!title || usedTitles.has(title)) continue;
        usedTitles.add(title);
        const image = item.thumbnail || item.enclosure?.link || item.image || `https://picsum.photos/seed/${encodeURIComponent(title)}/600/400`;
        allItems.push({
          title,
          description: cleanDesc(item.description || ''),
          url: item.link || item.url || source.homeUrl,
          image,
          published_at: item.pubDate || item.pub_date || new Date().toISOString(),
          source: source.name,
        });
      }
    } catch {}
  }

  allItems.sort((a, b) => new Date(b.published_at).getTime() - new Date(a.published_at).getTime());
  const topItems = allItems.slice(0, 6);

  if (topItems.length > 0) {
    const cards = topItems.map((item, i) => cardHTML(item, i, i === 0));
    const sources = NEWS_SOURCES.map(s => s.name).join(', ');
    serverHTML = `<div class="news-grid">${cards.join('')}</div>
      <p class="news-footer">Fontes: ${sources}</p>`;
  }
} catch (e) {}
---

<section id="noticias" class="section-padded section-surface" aria-labelledby="news-title">
  <div class="container">
    <header class="section-header">
      <h2 id="news-title" class="section-title">Notícias</h2>
      <p class="section-subtitle">Os principais acontecimentos do Brasil e do mundo</p>
    </header>

    <div id="news-root" class="news-root">
      {serverHTML ? (
        <Fragment set:html={serverHTML} />
      ) : (
        <div class="loading-root" aria-label="Carregando notícias...">
          <div class="spinner"></div>
          <span>Carregando notícias...</span>
        </div>
      )}
    </div>
  </div>
</section>

<script>
(function() {
  const r = document.getElementById('news-root');
  if (!r) return;

  const sources = [
    {name:'G1',feed:'https://g1.globo.com/rss/g1/',home:'https://g1.globo.com'},
    {name:'UOL',feed:'https://rss.uol.com.br/feed/noticias.xml',home:'https://noticias.uol.com.br'},
    {name:'Folha',feed:'https://feeds.folha.uol.com.br/folha/emcimadahora/rss091.xml',home:'https://www.folha.uol.com.br'},
    {name:'CNN Brasil',feed:'https://www.cnnbrasil.com.br/feed/',home:'https://www.cnnbrasil.com.br'},
    {name:'Estadão',feed:'https://www.estadao.com.br/rss/',home:'https://www.estadao.com.br'},
  ];
  const RSS2JSON = 'https://api.rss2json.com/v1/api.json';

  var _e={amp:'&',lt:'<',gt:'>',quot:'"',apos:"'",nbsp:'\xa0',aacute:'\xe1',eacute:'\xe9',iacute:'\xed',oacute:'\xf3',uacute:'\xfa',yacute:'\xfd',agrave:'\xe0',egrave:'\xe8',igrave:'\xec',ograve:'\xf2',ugrave:'\xf9',acirc:'\xe2',ecirc:'\xea',icirc:'\xee',ocirc:'\xf4',ucirc:'\xfb',atilde:'\xe3',otilde:'\xf5',ntilde:'\xf1',auml:'\xe4',euml:'\xeb',iuml:'\xef',ouml:'\xf6',uuml:'\xfc',yuml:'\xff',ccedil:'\xe7',Aacute:'\xc1',Eacute:'\xc9',Iacute:'\xcd',Oacute:'\xd3',Uacute:'\xda',Yacute:'\xdd',Agrave:'\xc0',Egrave:'\xc8',Igrave:'\xcc',Ograve:'\xd2',Ugrave:'\xd9',Acirc:'\xc2',Ecirc:'\xca',Icirc:'\xce',Ocirc:'\xd4',Ucirc:'\xdb',Atilde:'\xc3',Otilde:'\xd5',Ntilde:'\xd1',Auml:'\xc4',Euml:'\xcb',Iuml:'\xcf',Ouml:'\xd6',Uuml:'\xdc',Ccedil:'\xe7',szlig:'\xdf',ndash:'\u2013',mdash:'\u2014',lsquo:'\u2018',rsquo:'\u2019',ldquo:'\u201c',rdquo:'\u201d',bull:'\u2022',hellip:'\u2026',euro:'\u20ac',trade:'\u2122',copy:'\xa9',reg:'\xae',deg:'\xb0',laquo:'\xab',raquo:'\xbb',times:'\xd7',divide:'\xf7'};
  function de(s){return s.replace(/&#(\d+);/g,function(_,n){return String.fromCodePoint(+n)}).replace(/&#x([\da-f]+);/gi,function(_,n){return String.fromCodePoint(parseInt(n,16))}).replace(/&([a-z]+);/gi,function(_,n){return _e[n]||'&'+n+';'})}
  function cd(s){return de((s||'').replace(/<[^>]*>/g,'')).replace(/\s+/g,' ').trim().substring(0,200)}

  function ta(s) {
    var d = Math.floor((Date.now() - new Date(s).getTime()) / 1000);
    if (d < 60) return 'agora';
    if (d < 3600) return Math.floor(d / 60) + 'min';
    if (d < 86400) return Math.floor(d / 3600) + 'h';
    if (d < 172800) return 'ontem';
    return Math.floor(d / 86400) + 'd';
  }

  function ch(item, i, feat) {
    return '<a href="' + item.url + '" class="news-card' + (feat ? ' featured' : '') + ' stagger-item" target="_blank" rel="noopener" style="--news-color:#c06000;--i:' + i + '"><div class="news-card-img"><img src="' + item.image + '" alt="" loading="lazy" onerror="this.parentElement.classList.add(\'news-card-img--empty\')"><div class="news-card-img-overlay"></div><span class="news-card-badge">' + item.source + '</span></div><div class="news-card-body"><div class="news-card-meta"><span class="news-card-time">' + ta(item.published_at) + '</span><span class="news-card-source">' + item.source + '</span></div><h3 class="news-card-title">' + item.title + '</h3><p class="news-card-summary">' + (item.description || '') + '</p><span class="news-card-more">Ler matéria →</span></div></a>';
  }

  var fb = [
    {title:"Brasil registra avanço em indicadores econômicos",description:"Dados do Banco Central mostram recuperação consistente da atividade econômica.",url:"https://g1.globo.com",image:"https://picsum.photos/seed/g1f/600/400",published_at:new Date().toISOString(),source:"G1"},
    {title:"Câmara aprova texto-base da reforma tributária",description:"Proposta segue para o Senado com regime de urgência.",url:"https://www.folha.uol.com.br",image:"https://picsum.photos/seed/folhaf/600/400",published_at:new Date().toISOString(),source:"Folha"},
    {title:"Previsão do tempo: frente fria chega ao Sudeste",description:"Temperaturas devem cair com chegada de massa de ar polar.",url:"https://noticias.uol.com.br",image:"https://picsum.photos/seed/uolf/600/400",published_at:new Date().toISOString(),source:"UOL"},
    {title:"Mercado projeta inflação menor para 2026",description:"Boletim Focus mostra redução nas expectativas para o IPCA.",url:"https://www.estadao.com.br",image:"https://picsum.photos/seed/estaof/600/400",published_at:new Date().toISOString(),source:"Estadão"},
  ];

  async function load() {
    r.innerHTML = '<div class="loading-root"><div class="spinner"></div><span>Carregando notícias...</span></div>';
    var all = [];
    var used = {};

    for (var si = 0; si < sources.length; si++) {
      try {
        var res = await fetch(RSS2JSON + '?rss_url=' + encodeURIComponent(sources[si].feed), {signal: AbortSignal.timeout(6000)});
        if (!res.ok) continue;
        var data = await res.json();
        if (data.status !== 'ok' || !data.items) continue;
        for (var j = 0; j < data.items.length; j++) {
          var item = data.items[j];
          if (!item.title || used[item.title]) continue;
          used[item.title] = 1;
          all.push({
            title: item.title,
          description: cd(item.description),
            url: item.link || item.url || sources[si].home,
            image: item.thumbnail || item.enclosure?.link || item.image || 'https://picsum.photos/seed/' + encodeURIComponent(item.title) + '/600/400',
            published_at: item.pubDate || item.pub_date || new Date().toISOString(),
            source: sources[si].name,
          });
        }
      } catch(e) {}
    }

    all.sort(function(a,b) { return new Date(b.published_at).getTime() - new Date(a.published_at).getTime(); });
    var items = all.slice(0, 6);
    if (items.length === 0) items = fb;

    var cards = '';
    for (var k = 0; k < items.length; k++) {
      cards += ch(items[k], k, k === 0);
    }
    var srcs = '';
    for (var s = 0; s < sources.length; s++) {
      if (s > 0) srcs += ', ';
      srcs += sources[s].name;
    }
    r.innerHTML = '<div class="news-grid">' + cards + '</div><p class="news-footer">Fontes: ' + srcs + '</p>';
  }

  load();
  setInterval(load, 300000);
})();
</script>

<style is:global>
  .news-root { min-height: 200px; }
  .news-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-3); }
  @media (max-width: 768px) { .news-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 480px) { .news-grid { grid-template-columns: 1fr; } }
  .news-card {
    display: flex; flex-direction: column; overflow: hidden;
    text-decoration: none; color: inherit;
    transition: all var(--duration-base) var(--ease-spring);
    border-top: 3px solid var(--news-color, var(--color-primary));
  }
  .news-card:hover { transform: translateY(-4px); box-shadow: 0 12px 32px rgba(0,0,0,0.12); text-decoration: none; }
  .news-card.featured { border-top-width: 4px; }
  .news-card.featured .news-card-title { font-size: var(--text-base); }
  .news-card-img { position: relative; width: 100%; height: 140px; overflow: hidden; background: var(--color-surface-elevated); }
  .news-card-img--empty { background: linear-gradient(135deg, var(--color-surface-elevated), var(--color-surface)); }
  .news-card-img img { width: 100%; height: 100%; object-fit: cover; transition: transform var(--duration-slow) var(--ease-out-quart); }
  .news-card:hover .news-card-img img { transform: scale(1.08); }
  .news-card-img-overlay { position: absolute; inset: 0; background: linear-gradient(180deg, transparent 60%, rgba(0,0,0,0.4)); pointer-events: none; }
  .news-card-badge {
    position: absolute; top: var(--space-3); left: var(--space-3);
    padding: 3px 12px; border-radius: 9999px;
    font-size: 11px; font-weight: var(--weight-bold); color: white;
    text-transform: uppercase; letter-spacing: 0.05em;
    background: var(--news-color, var(--color-primary));
  }
  .news-card-body {
    padding: var(--space-3); flex: 1;
    display: flex; flex-direction: column; gap: var(--space-1);
    background: var(--color-surface-elevated);
  }
  .news-card-meta { display: flex; gap: var(--space-2); font-size: 10px; color: var(--color-ink-subtle); }
  .news-card-time, .news-card-source { display: inline-flex; align-items: center; }
  .news-card-time::after { content: '·'; margin-left: var(--space-2); opacity: 0.5; }
  .news-card-source { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .news-card-title {
    font-size: var(--text-sm); font-weight: var(--weight-bold);
    color: var(--color-ink); line-height: var(--leading-snug);
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
  }
  .news-card-summary {
    font-size: var(--text-sm); color: var(--color-ink-muted);
    line-height: var(--leading-normal);
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
  }
  .news-card-more { font-size: var(--text-sm); font-weight: var(--weight-semibold); color: var(--news-color, var(--color-primary)); margin-top: auto; }
  .news-footer { text-align: center; margin-top: var(--space-4); font-size: var(--text-xs); color: var(--color-ink-subtle); }
  .news-card.stagger-item { animation-delay: calc(var(--i, 0) * 60ms); }
</style>
