---
/**
 * PlayerBar — Barra de player fixa no rodapé
 * Hydrated com client:visible (carrega quando visível)
 */
import type { AstroProps } from 'astro';
import { STATION, SCHEDULE } from '../config.ts';

interface Props extends AstroProps {
  streamUrl?: string;
}

const { streamUrl = STATION.url } = Astro.props;
const now = new Date();
const currentHour = now.getHours();
const currentMinute = now.getMinutes();
const currentTime = currentHour * 60 + currentMinute;

function getCurrentProgram() {
  for (const item of SCHEDULE) {
    const [startStr] = item.time.split(' - ');
    const [startH, startM] = startStr.split(':').map(Number);
    const start = startH * 60 + startM;
    const [endStr] = item.time.split(' - ')[1].split(':');
    const [endH, endM] = item.time.split(' - ')[1].split(':').map(Number);
    const end = endH * 60 + endM;
    if (currentTime >= start && currentTime < end) {
      return item;
    }
  }
  return SCHEDULE[0];
}

const currentProgram = getCurrentProgram();
const presenter = Array.isArray(currentProgram.presenters)
  ? currentProgram.presenters.join(', ')
  : currentProgram.presenter || currentProgram.presenters?.[0] || '';
---

<style>
  /* ===== Player Bar ===== */
  .player-bar {
    position: fixed;
    bottom: 0; left: 0; right: 0;
    height: var(--player-height);
    background: var(--color-surface-elevated);
    border-top: 1px solid var(--color-border);
    backdrop-filter: blur(8px);
    display: flex;
    align-items: center;
    gap: var(--space-4);
    padding: 0 var(--space-4);
    z-index: var(--z-player);
    animation: slide-up-fade var(--duration-base) var(--ease-out-quart);
  }

  @media (max-width: 480px) {
    .player-bar { height: var(--player-height-mobile); }
  }

  @keyframes slide-up-fade {
    from { opacity: 0; transform: translateY(100%); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* ===== Live Badge ===== */
  .live-badge {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    padding: var(--space-1) var(--space-2);
    border-radius: var(--radius-full);
    background: var(--color-accent);
    color: white;
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .live-badge::before {
    content: "";
    width: 6px; height: 6px;
    background: currentColor;
    border-radius: 50%;
    animation: pulse-live 1.5s ease-in-out infinite;
  }

  @keyframes pulse-live {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.6; transform: scale(1.05); }
  }

  @media (prefers-reduced-motion: reduce) {
    .live-badge::before { animation: none; opacity: 1; }
  }

  /* ===== Now Playing ===== */
  .now-playing {
    flex: 1;
    min-width: 0;
    overflow: hidden;
  }

  .station-name {
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    color: var(--color-ink);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .program-info {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-xs);
    color: var(--color-ink-muted);
    white-space: nowrap;
    overflow: hidden;
  }

  .program-time {
    font-variant-numeric: tabular-nums;
    font-weight: var(--weight-medium);
  }

  .program-separator { opacity: 0.4; }

  .program-title {
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 200px;
  }

  @media (max-width: 480px) {
    .program-title { max-width: 120px; }
  }

  /* ===== Play Button ===== */
  .btn-play {
    width: 48px; height: 48px;
    border-radius: var(--radius-full);
    background: var(--color-primary);
    color: white;
    border: none;
    display: flex; align-items: center; justify-content: center;
    cursor: pointer;
    flex-shrink: 0;
    transition:
      background-color var(--duration-base) var(--ease-out-quart),
      transform var(--duration-fast) var(--ease-spring);
  }

  .btn-play:hover { background: var(--color-primary-hover); }
  .btn-play:active { transform: scale(0.92); }
  .btn-play:focus-visible {
    outline: 2px solid var(--color-focus);
    outline-offset: 2px;
  }

  .btn-play.playing { background: var(--color-success); }
  .btn-play.playing:hover { background: var(--color-success-hover); }
  .btn-play.error { background: var(--color-error); }
  .btn-play.error:hover { background: var(--color-error-hover); }
  .btn-play:disabled { opacity: 0.5; cursor: not-allowed; }

  .btn-play svg { width: 24px; height: 24px; }
  .btn-play.playing .icon-play { display: none; }
  .btn-play:not(.playing) .icon-pause { display: none; }
  .btn-play.buffering .icon-play,
  .btn-play.buffering .icon-pause { display: none; }
  .btn-play.buffering .icon-spinner { display: block; }

  .icon-spinner {
    display: none;
    width: 20px; height: 20px;
    border: 2px solid transparent;
    border-top-color: currentColor;
    border-radius: 50%;
    animation: spin-buffer 0.8s linear infinite;
  }

  @keyframes spin-buffer {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  @media (prefers-reduced-motion: reduce) {
    .icon-spinner { animation: none; border-top-color: transparent; }
  }

  /* ===== Volume Button (opcional v1) ===== */
  .btn-volume {
    width: 40px; height: 40px;
    border-radius: var(--radius-full);
    background: transparent;
    color: var(--color-ink-muted);
    border: none;
    display: flex; align-items: center; justify-content: center;
    cursor: pointer;
    transition: color var(--duration-fast) var(--ease-out-quart);
  }

  .btn-volume:hover { color: var(--color-ink); }
  .btn-volume:focus-visible {
    outline: 2px solid var(--color-focus);
    outline-offset: 2px;
  }

  .btn-volume svg { width: 20px; height: 20px; }

  /* Esconde a barra após erro persistente */
  .player-bar.hidden { display: none; }
</style>

<div class="player-bar" role="region" aria-label="Player de stream ao vivo" data-player-bar>
  <!-- Live Badge -->
  <span class="live-badge" aria-live="polite" aria-atomic="true">AO VIVO</span>

  <!-- Now Playing Info -->
  <div class="now-playing">
    <div class="station-name" data-station-name>{STATION.name}</div>
    <div class="program-info" data-program-info>
      <span class="program-time" data-program-time>{currentProgram.time}</span>
      <span class="program-separator" aria-hidden="true">·</span>
      <span class="program-title" data-program-title>{currentProgram.program}</span>
      {presenter && (
        <>
          <span class="program-separator" aria-hidden="true">·</span>
          <span class="program-presenter" data-program-presenter>{presenter}</span>
        </>
      )}
    </div>
  </div>

  <!-- Play/Pause Button -->
  <button
    class="btn-play"
    id="play-btn"
    aria-label="Tocar stream ao vivo"
    aria-pressed="false"
    data-play-btn
  >
    <svg class="icon-play" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M8 5v14l11-7z"/>
    </svg>
    <svg class="icon-pause" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/>
    </svg>
    <svg class="icon-spinner" viewBox="0 0 24 24" aria-hidden="true">
      <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3" fill="none" stroke-dasharray="30 30" stroke-linecap="round"/>
    </svg>
  </button>

  <!-- Volume Button (placeholder v1) -->
  <button
    class="btn-volume"
    id="volume-btn"
    aria-label="Controlar volume"
    data-volume-btn
  >
    <svg class="icon-volume-high" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M3 9v6h4l5 5V4L7 9H3zm13.5 3c0-1.77-1.02-3.29-2.5-4.03v8.05c1.48-.73 2.5-2.25 2.5-4.02z"/>
    </svg>
    <svg class="icon-volume-low" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" style="display:none">
      <path d="M18.5 12c0-1.77-1.02-3.29-2.5-4.03v8.05c1.48-.73 2.5-2.25 2.5-4.02zM5 9v6h4l5 5V4L9 9H5z"/>
    </svg>
    <svg class="icon-volume-mute" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" style="display:none">
      <path d="M16.5 12c0-1.77-1.02-3.29-2.5-4.03v2.21l2.45 2.45c.03-.2.05-.41.05-.63zm2.5 0c0 .94-.2 1.82-.54 2.64l1.51 1.51C20.63 14.91 21 13.5 21 12c0-4.28-2.99-7.86-7-8.77v2.06c2.89.86 5 3.54 5 6.71zM4.27 3L3 4.27 7.73 9H3v6h4l5 5v-6.73l4.25 4.25c-.67.52-1.42.93-2.25 1.18v2.06c1.38-.31 2.63-.95 3.69-1.81L19.73 21 21 19.73l-9-9L4.27 3zM12 4L9.91 6.09 12 8.18V4z"/>
    </svg>
  </button>
</div>

<script is:inline define:vars={{ SCHEDULE, RAW_STREAM_URL: STATION.url }}>
  // ===== PlayerBar Logic (Vanilla JS, roda no cliente) =====
  (function() {
    'use strict';

    // Em HTTPS (produção) o stream http é bloqueado por mixed content,
    // então tentamos múltiplos proxies CORS com fallback automático.
    const PROXIES = [
      (url) => 'https://corsproxy.io/?url=' + encodeURIComponent(url),
      (url) => 'https://corsproxy.org/?' + encodeURIComponent(url),
    ];
    const streamDirect = RAW_STREAM_URL;
    const isHttps = location.protocol === 'https:';

    // Gera a lista de URLs para tentar: proxies primeiro, depois direto (fallback)
    function getStreamUrls() {
      const urls = [];
      if (isHttps) {
        for (const p of PROXIES) urls.push(p(streamDirect));
      }
      urls.push(streamDirect);
      return urls;
    }

    let streamUrlIndex = 0;
    const STREAM_URLS = getStreamUrls();

    const playBtn = document.getElementById('play-btn');
    const volumeBtn = document.getElementById('volume-btn');
    const stationNameEl = document.querySelector('[data-station-name]');
    const programTitleEl = document.querySelector('[data-program-title]');
    const programTimeEl = document.querySelector('[data-program-time]');
    const programPresenterEl = document.querySelector('[data-program-presenter]');

    if (!playBtn) return;

    let audio = null;
    let isPlaying = false;
    let isBuffering = false;
    let metadataInterval = null;
    let retryCount = 0;
    const MAX_RETRIES = 3;

    // ===== Initialize Audio =====
    function initAudio() {
      if (audio) return;
      audio = new Audio();
      audio.preload = 'metadata';
      audio.crossOrigin = 'anonymous';
      setAudioSource(streamUrlIndex);

      audio.addEventListener('loadstart', onLoadStart);
      audio.addEventListener('canplay', onCanPlay);
      audio.addEventListener('playing', onPlaying);
      audio.addEventListener('pause', onPause);
      audio.addEventListener('error', onError);
      audio.addEventListener('waiting', onWaiting);
      audio.addEventListener('stalled', onStalled);
      audio.addEventListener('ended', onEnded);
    }

    function setAudioSource(index) {
      if (!audio) return;
      const url = STREAM_URLS[index] || STREAM_URLS[0];
      audio.src = url;
      streamUrlIndex = index;
    }

    // ===== Event Handlers =====
    function onLoadStart() {
      setBuffering(true);
    }

    function onCanPlay() {
      setBuffering(false);
    }

    function onPlaying() {
      isPlaying = true;
      retryCount = 0;
      updatePlayButton();
      startMetadataPolling();
    }

    function onPause() {
      isPlaying = false;
      updatePlayButton();
      stopMetadataPolling();
    }

    function onWaiting() {
      setBuffering(true);
    }

    function onStalled() {
      setBuffering(true);
    }

    function onEnded() {
      isPlaying = false;
      updatePlayButton();
      stopMetadataPolling();
    }

    function onError(e) {
      console.error('[PlayerBar] Stream error:', e);
      stopMetadataPolling();
      setBuffering(false);

      // Tentar próximo proxy na lista
      const nextIndex = streamUrlIndex + 1;
      if (nextIndex < STREAM_URLS.length) {
        console.log('[PlayerBar] Tentando proxy alternativo:', nextIndex);
        retryCount = 0;
        setAudioSource(nextIndex);
        if (audio) {
          audio.load();
          audio.play().catch(() => {});
        }
      } else if (retryCount < MAX_RETRIES) {
        retryCount++;
        setTimeout(() => {
          if (audio) {
            setAudioSource(streamUrlIndex);
            audio.load();
            playBtn.click();
          }
        }, 1000 * retryCount);
      } else {
        setError(true);
        setTimeout(() => {
          document.querySelector('[data-player-bar]')?.classList.add('hidden');
        }, 5000);
      }
    }

    // ===== UI State =====
    function setBuffering(buffering) {
      isBuffering = buffering;
      playBtn.classList.toggle('buffering', buffering);
      playBtn.disabled = buffering;
      if (buffering) {
        playBtn.setAttribute('aria-label', 'Carregando stream...');
      } else {
        playBtn.setAttribute('aria-label', isPlaying ? 'Pausar stream' : 'Tocar stream ao vivo');
      }
    }

    function setError(hasError) {
      playBtn.classList.toggle('error', hasError);
      playBtn.classList.remove('playing', 'buffering');
      if (hasError) {
        playBtn.setAttribute('aria-label', 'Erro ao conectar. Toque para tentar novamente');
      }
    }

    function updatePlayButton() {
      playBtn.classList.toggle('playing', isPlaying);
      playBtn.classList.remove('buffering', 'error');
      playBtn.setAttribute('aria-pressed', isPlaying.toString());
      playBtn.setAttribute('aria-label', isPlaying ? 'Pausar stream' : 'Tocar stream ao vivo');
    }

    // ===== Metadata Polling (Icecast/Shoutcast) =====
    function startMetadataPolling() {
      stopMetadataPolling();
      // Poll a cada 10s para metadados icy
      metadataInterval = setInterval(fetchMetadata, 10000);
      fetchMetadata(); // imediato
    }

    function stopMetadataPolling() {
      if (metadataInterval) {
        clearInterval(metadataInterval);
        metadataInterval = null;
      }
    }

    async function fetchMetadata() {
      try {
        // Tentar buscar metadados do Icecast/Shoutcast
        // Muitos servidores expõem /status.xsl ou /status-json.xsl
        const metadataUrl = RAW_STREAM_URL.replace(/\/stream\/?$/, '/status-json.xsl');
        const res = await fetch(metadataUrl, { mode: 'cors' });
        if (!res.ok) throw new Error('Metadata not available');
        const data = await res.json();
        // Shoutcast v2 JSON: icestats.source[0].title
        const source = data.icestats?.source?.[0] || data.icestats?.source;
        if (source?.title) {
          updateNowPlaying(source.title);
        }
      } catch (e) {
        // Silencioso - fallback para schedule estático
        // console.debug('[PlayerBar] Metadata fetch failed, using schedule');
      }
    }

    function updateNowPlaying(title) {
      if (programTitleEl) {
        programTitleEl.textContent = title;
      }
    }

    // ===== Volume Control (placeholder v1) =====
    let isMuted = false;
    let lastVolume = 1;

    function toggleMute() {
      if (!audio) return;
      isMuted = !isMuted;
      audio.muted = isMuted;
      updateVolumeIcon();
    }

    function updateVolumeIcon() {
      const high = volumeBtn.querySelector('.icon-volume-high');
      const low = volumeBtn.querySelector('.icon-volume-low');
      const mute = volumeBtn.querySelector('.icon-volume-mute');
      if (!high || !low || !mute) return;

      high.style.display = 'none';
      low.style.display = 'none';
      mute.style.display = 'none';

      if (isMuted || audio.volume === 0) {
        mute.style.display = 'block';
      } else if (audio.volume < 0.5) {
        low.style.display = 'block';
      } else {
        high.style.display = 'block';
      }
    }

    // ===== Event Listeners =====
    playBtn.addEventListener('click', async () => {
      initAudio();

      if (isPlaying) {
        audio.pause();
      } else {
        // Resetar para o primeiro proxy ao tentar tocar novamente
        if (playBtn.classList.contains('error')) {
          setAudioSource(0);
        }
        setBuffering(true);
        try {
          await audio.play();
        } catch (e) {
          console.error('[PlayerBar] Play failed:', e);
          setBuffering(false);
          setError(true);
        }
      }
    });

    volumeBtn.addEventListener('click', toggleMute);

    // Keyboard support
    playBtn.addEventListener('keydown', (e) => {
      if (e.key === ' ' || e.key === 'Enter') {
        e.preventDefault();
        playBtn.click();
      }
    });

    // Cleanup on unload
    window.addEventListener('beforeunload', () => {
      stopMetadataPolling();
      if (audio) {
        audio.pause();
        audio.src = '';
      }
    });

    // Initialize schedule-based now-playing (fallback)
    function updateScheduleNowPlaying() {
      const now = new Date();
      const currentHour = now.getHours();
      const currentMinute = now.getMinutes();
      const currentTime = currentHour * 60 + currentMinute;

      for (const item of SCHEDULE) {
        const [startStr, endStr] = item.time.split(' - ');
        const [startH, startM] = startStr.split(':').map(Number);
        const [endH, endM] = endStr.split(':').map(Number);
        const start = startH * 60 + startM;
        const end = endH * 60 + endM;

        if (currentTime >= start && currentTime < end) {
          if (programTitleEl) programTitleEl.textContent = item.program;
          if (programTimeEl) programTimeEl.textContent = item.time;
          if (programPresenterEl) {
            const presenter = Array.isArray(item.presenters)
              ? item.presenters.join(', ')
              : item.presenter || item.presenters?.[0] || '';
            programPresenterEl.textContent = presenter;
            programPresenterEl.style.display = presenter ? 'inline' : 'none';
            document.querySelector('.program-separator:nth-of-type(2)')?.style.setProperty('display', presenter ? 'inline' : 'none');
          }
          break;
        }
      }
    }

    // Atualiza schedule a cada minuto
    setInterval(updateScheduleNowPlaying, 60000);
    updateScheduleNowPlaying();

    // Expor para debug
    window.__esmeraldaPlayer = { audio, playBtn, volumeBtn };
  })();
</script>