---
/**
 * Home Page — Esmeralda Web Rádio
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import { STATION, SCHEDULE, CONTACT, APPS } from '../config.ts';
---

<BaseLayout title="Esmeralda Web Rádio - Ao Vivo" description={STATION.name + ' - ' + 'A rádio web moderna que conecta você com música e entretenimento de qualidade.'}>
  <main id="main-content">
    <!-- Hero / Header Section -->
    <section class="hero" aria-labelledby="hero-title">
      <div class="container">
        <div class="hero-content">
          <h1 id="hero-title" class="hero-title">Esmeralda Web Rádio</h1>
          <p class="hero-tagline">A rádio web moderna que conecta você com música e entretenimento de qualidade.</p>
          <div class="hero-badges">
            <span class="badge badge-live" aria-live="polite">AO VIVO</span>
            <span class="badge badge-quality">Stream 128kbps</span>
            <span class="badge badge-platform">Web + Mobile</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Programação -->
    <section id="programacao" class="schedule-section" aria-labelledby="schedule-title">
      <div class="container">
        <header class="section-header">
          <h2 id="schedule-title" class="section-title">Programação Diária</h2>
          <p class="section-subtitle">Das 06:00 às 18:00, ao vivo para você</p>
        </header>

        <div class="schedule-grid" role="list" aria-label="Grade de programação">
          {SCHEDULE.map((item, index) => {
            const now = new Date();
            const currentHour = now.getHours();
            const currentMinute = now.getMinutes();
            const currentTime = currentHour * 60 + currentMinute;
            const [startStr, endStr] = item.time.split(' - ');
            const [startH, startM] = startStr.split(':').map(Number);
            const [endH, endM] = endStr.split(':').map(Number);
            const start = startH * 60 + startM;
            const end = endH * 60 + endM;
            const isCurrent = currentTime >= start && currentTime < end;
            const presenter = Array.isArray(item.presenters)
              ? item.presenters.join(', ')
              : item.presenter || item.presenters?.[0] || '';

            return (
              <article
                class={`schedule-card ${isCurrent ? 'current' : ''}`}
                role="listitem"
                aria-current={isCurrent ? 'time' : undefined}
              >
                {isCurrent && <span class="on-air-badge" aria-label="No ar agora">NO AR</span>}
                <time class="schedule-time" dateTime={item.time}>{item.time}</time>
                <h3 class="schedule-program">{item.program}</h3>
                {presenter && <p class="schedule-presenter">Com {presenter}</p>}
                <p class="schedule-description">{item.description}</p>
              </article>
            );
          })}
        </div>
      </div>
    </section>

    <!-- Sobre / Contato -->
    <section id="sobre" class="about-section" aria-labelledby="about-title">
      <div class="container">
        <div class="about-grid">
          <div class="about-content">
            <h2 id="about-title" class="section-title">Sobre a Esmeralda Web Rádio</h2>
            <p class="about-text">
              Somos uma rádio web brasileira feita para acompanhar o seu dia.
              Do sertanejo ao pop internacional, dos clássicos dos anos 80 ao jornalismo local,
              nossa programação foi pensada para quem gosta de música de verdade
              e informação relevante — seja no trânsito, no trabalho ou em casa.
            </p>
            <p class="about-text">
              Com transmissão estável via <strong>FastCast</strong> (128kbps),
              fallback automático para HTTPS via proxy CORS e player nativo no navegador,
              a Esmeralda Web Rádio funciona em qualquer dispositivo sem precisar instalar nada.
            </p>
          </div>

          <aside class="about-contact" aria-labelledby="contact-title">
            <h3 id="contact-title" class="section-title section-title-sm">Fale Conosco</h3>
            <address class="contact-list">
              <a href={`https://wa.me/${CONTACT.whatsapp}`} target="_blank" rel="noopener" class="contact-item">
                <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.472.099-.174.05-.372-.025-.52-.075-.148-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.378-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.672zm-4.864 4.123c-.51-.338-1.12-.77-1.56-1.228-.44-.459-.72-.93-.89-1.26-.173-.33-.223-.473-.248-.62-.024-.148-.025-.273.024-.423.049-.149.198-.347.397-.57.198-.198.647-.744 1.09-1.39.44-.646.893-1.25 1.13-1.645.248-.41.273-.52.322-.572.173-.173.63-.743 1.362-1.474.472-.472.83-.87 1.01-1.12.173-.248.148-.373.12-.473-.024-.074-.273-.915-.916-2.472-.642-1.56-1.48-2.908-2.57-3.797-.883-.71-1.82-1.326-2.894-1.82-.173-.075-.52-.075-.72 0-1.073.524-1.876 1.56-2.517 2.698-.61 1.09-1.09 2.114-1.317 2.863-.198.67-.223 1.018-.198 1.09.025.098.373.418.773 1.018.598.6 1.37 1.598 2.147 2.41.78.81 1.53 1.505 2.143 2.075.61.57 1.12 1.01 1.51 1.318.39.307.706.54 1.09.647.397.12.572.167.84.149l.223-.024c.223-.024.42-.174.547-.4.124-.223.148-.472.099-.62-.049-.148-.198-.447-.322-.62-.124-.173-.598-.723-1.466-1.872-.868-1.148-1.69-2.147-2.44-3.065-.75-.917-1.406-1.71-1.96-2.38-.55-.67-.89-1.27-1.16-1.773-.273-.504-.248-.778-.223-.916.022-.148.048-.298.097-.422.049-.125.173-.373.298-.62.124-.248.373-.473.697-.698.324-.224.72-.273 1.1-.248.373.025.697.174.97.398.273.223.447.52.52.797.073.273.024.52-.148.697-.173.173-.472.298-.897.423-.425.124-.85.1-.94.125-.074.025-.223.074-.447.124-.223.05-.497.074-.747.099-.248.024-.473.024-.697.024-.224 0-.448-.025-.67-.049z"/></svg>
                <span>WhatsApp: +55 74 99999-9999</span>
              </a>
              <a href={`mailto:${CONTACT.email}`} class="contact-item">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
                <span>contato@esmeraldawebradio.com.br</span>
              </a>
            </address>

            <h3 class="section-title section-title-sm" style="margin-top: var(--space-6);">Baixe o App</h3>
            <div class="app-links">
              <a href={APPS.appStore} target="_blank" rel="noopener" class="app-link">
                <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.71 14.3c.38.35.55.9.55 1.45 0 1.32-1.08 2.4-2.4 2.4-.53 0-1.02-.21-1.38-.54l-2.65-2.37c-.63-.56-1.5-.56-2.13 0l-2.65 2.37c-.36.33-.85.54-1.38.54-1.32 0-2.4-1.08-2.4-2.4 0-.55.17-1.1.55-1.45l3.28-3.48c.2-.21.2-.55 0-.76l-3.28-3.48C7.93 4.1 7.76 3.55 7.76 3c0-.55-.45-1-1-1s-1 .45-1 1c0 .55.16 1.1.55 1.45l3.97 4.21c.2.21.2.55 0 .76l-3.97 4.21c-.38.35-.55.9-.55 1.45 0 1.32 1.08 2.4 2.4 2.4.53 0 1.02-.21 1.38-.54l2.65-2.37c.63-.56 1.5-.56 2.13 0l2.65 2.37c.36.33.85.54 1.38.54 1.32 0 2.4-1.08 2.4-2.4 0-.55-.17-1.1-.55-1.45l-3.28-3.48c-.2-.21-.2-.55 0-.76l3.28-3.48z"/></svg>
                <span>App Store</span>
              </a>
              <a href={APPS.googlePlay} target="_blank" rel="noopener" class="app-link">
                <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M21.88 14.32c0 .52-.42.95-.95.95H2.08c-.52 0-.95-.42-.95-.95V9.68c0-.52.42-.95.95-.95h18.85c.52 0 .95.42.95.95v4.64zM12 4.5c-3.59 0-6.5 2.91-6.5 6.5s2.91 6.5 6.5 6.5 6.5-2.91 6.5-6.5-2.91-6.5-6.5-6.5zm0 12c-3.04 0-5.5-2.46-5.5-5.5s2.46-5.5 5.5-5.5 5.5 2.46 5.5 5.5-2.46 5.5-5.5 5.5z"/></svg>
                <span>Google Play</span>
              </a>
            </div>
          </aside>
        </div>
      </div>
    </section>

    <!-- Redes Sociais -->
    <section class="social-section" aria-labelledby="social-title">
      <div class="container">
        <header class="section-header">
          <h2 id="social-title" class="section-title">Siga a Esmeralda</h2>
          <p class="section-subtitle">Acompanhe bastidores, promoções e novidades</p>
        </header>
        <div class="social-grid">
          <a href="https://instagram.com/esmeraldawebradio" target="_blank" rel="noopener" class="social-card instagram" aria-label="Instagram da Esmeralda Web Rádio">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
            <span>@esmeraldawebradio</span>
          </a>
          <a href="https://facebook.com/esmeraldawebradio" target="_blank" rel="noopener" class="social-card facebook" aria-label="Facebook da Esmeralda Web Rádio">
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
            <span>/esmeraldawebradio</span>
          </a>
          <a href="https://youtube.com/@esmeraldawebradio" target="_blank" rel="noopener" class="social-card youtube" aria-label="YouTube da Esmeralda Web Rádio">
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
            <span>@esmeraldawebradio</span>
          </a>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  /* ===== Hero ===== */
  .hero {
    padding: var(--space-16) 0 var(--space-12);
    text-align: center;
    background:
      radial-gradient(ellipse 80% 50% at 50% 0%, oklch(from var(--color-primary) l c h / 0.08), transparent),
      radial-gradient(ellipse 60% 40% at 100% 100%, oklch(from var(--color-accent) l c h / 0.06), transparent);
  }

  .hero-title {
    font-size: var(--text-display);
    font-weight: var(--weight-bold);
    letter-spacing: var(--text-display-ls);
    line-height: var(--leading-tight);
    color: var(--color-ink);
    margin-bottom: var(--space-4);
  }

  .hero-tagline {
    font-size: var(--text-lg);
    color: var(--color-ink-muted);
    max-width: 60ch;
    margin: 0 auto var(--space-8);
    line-height: var(--leading-relaxed);
  }

  .hero-badges {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-2);
  }

  .badge {
    display: inline-flex;
    align-items: center;
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-full);
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
  }

  .badge-live {
    background: var(--color-accent);
    color: white;
    animation: pulse-badge 2s ease-in-out infinite;
  }

  .badge-quality {
    background: var(--color-surface-elevated);
    border: 1px solid var(--color-border);
    color: var(--color-ink-muted);
  }

  .badge-platform {
    background: oklch(from var(--color-primary) l c h / 0.12);
    border: 1px solid oklch(from var(--color-primary) l c h / 0.3);
    color: var(--color-primary);
  }

  @keyframes pulse-badge {
    0%, 100% { box-shadow: 0 0 0 0 oklch(from var(--color-accent) l c h / 0.4); }
    50% { box-shadow: 0 0 0 8px oklch(from var(--color-accent) l c h / 0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .badge-live { animation: none; }
  }

  /* ===== Section Header ===== */
  .section-header { text-align: center; margin-bottom: var(--space-10); }
  .section-title {
    font-size: var(--text-h2);
    font-weight: var(--weight-bold);
    color: var(--color-ink);
    margin-bottom: var(--space-2);
  }
  .section-title-sm { font-size: var(--text-base); margin-bottom: var(--space-3); }
  .section-subtitle { color: var(--color-ink-muted); font-size: var(--text-base); }

  /* ===== Schedule Grid ===== */
  .schedule-section { padding: var(--space-12) 0 var(--space-16); }
  .schedule-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--space-4);
  }

  .schedule-card {
    position: relative;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-5);
    transition:
      border-color var(--duration-base) var(--ease-out-quart),
      box-shadow var(--duration-base) var(--ease-out-quart),
      background-color var(--duration-base) var(--ease-out-quart);
  }

  .schedule-card:hover {
    border-color: var(--color-border-strong);
    box-shadow: 0 4px 12px oklch(0 0 0 / 0.08);
  }

  .schedule-card.current {
    border-color: var(--color-primary);
    background: oklch(from var(--color-primary) l c h / 0.06);
  }

  .on-air-badge {
    position: absolute;
    top: -10px; right: var(--space-4);
    background: var(--color-accent);
    color: white;
    font-size: var(--text-xs);
    font-weight: var(--weight-bold);
    padding: 2px 8px;
    border-radius: var(--radius-full);
    white-space: nowrap;
    box-shadow: 0 2px 8px oklch(from var(--color-accent) l c h / 0.3);
  }

  .schedule-time {
    display: block;
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    color: var(--color-primary);
    font-variant-numeric: tabular-nums;
    margin-bottom: var(--space-1);
  }

  .schedule-program {
    font-size: var(--text-lg);
    font-weight: var(--weight-semibold);
    color: var(--color-ink);
    margin-bottom: var(--space-1);
  }

  .schedule-presenter {
    font-size: var(--text-sm);
    color: var(--color-ink-muted);
    margin-bottom: var(--space-2);
  }

  .schedule-description {
    font-size: var(--text-sm);
    color: var(--color-ink-subtle);
    line-height: var(--leading-normal);
  }

  /* ===== About Section ===== */
  .about-section { padding: var(--space-16) 0; background: var(--color-surface); }
  .about-grid {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: var(--space-12);
    align-items: start;
  }

  @media (max-width: 768px) {
    .about-grid { grid-template-columns: 1fr; }
  }

  .about-text {
    color: var(--color-ink-muted);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-4);
  }
  .about-text:last-child { margin-bottom: 0; }

  .about-contact { padding-left: var(--space-8); border-left: 1px solid var(--color-border); }

  @media (max-width: 768px) {
    .about-contact { padding-left: 0; border-left: none; border-top: 1px solid var(--color-border); padding-top: var(--space-8); }
  }

  .contact-list { display: flex; flex-direction: column; gap: var(--space-3); }
  .contact-item {
    display: flex; align-items: center; gap: var(--space-2);
    color: var(--color-ink-muted);
    font-size: var(--text-sm);
    transition: color var(--duration-fast);
  }
  .contact-item:hover { color: var(--color-primary); text-decoration: none; }
  .contact-item svg { width: 20px; height: 20px; flex-shrink: 0; color: var(--color-primary); }

  .app-links { display: flex; flex-direction: column; gap: var(--space-2); margin-top: var(--space-4); }
  .app-link {
    display: flex; align-items: center; gap: var(--space-2);
    padding: var(--space-2) var(--space-3);
    background: var(--color-surface-elevated);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    color: var(--color-ink);
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    transition: all var(--duration-fast) var(--ease-out-quart);
  }
  .app-link:hover { border-color: var(--color-primary); transform: translateX(4px); }
  .app-link svg { width: 24px; height: 24px; }

  /* ===== Social Section ===== */
  .social-section { padding: var(--space-12) 0 var(--space-16); }
  .social-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-4);
  }

  @media (max-width: 640px) {
    .social-grid { grid-template-columns: 1fr; }
  }

  .social-card {
    display: flex; align-items: center; gap: var(--space-3);
    padding: var(--space-4) var(--space-5);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    color: var(--color-ink);
    font-weight: var(--weight-medium);
    font-size: var(--text-base);
    transition: all var(--duration-base) var(--ease-out-quart);
  }
  .social-card:hover { border-color: currentColor; transform: translateY(-2px); box-shadow: 0 8px 24px oklch(0 0 0 / 0.1); text-decoration: none; }
  .social-card svg { width: 24px; height: 24px; flex-shrink: 0; }

  .social-card.instagram { color: #E1306C; }
  .social-card.instagram:hover { background: linear-gradient(45deg, #f09433 0%,#e6683c 25%,#dc2743 50%,#cc2366 75%,#bc1888 100%); color: white; border-color: transparent; }

  .social-card.facebook { color: #1877F2; }
  .social-card.facebook:hover { background: #1877F2; color: white; border-color: transparent; }

  .social-card.youtube { color: #FF0000; }
  .social-card.youtube:hover { background: #FF0000; color: white; border-color: transparent; }
</style>